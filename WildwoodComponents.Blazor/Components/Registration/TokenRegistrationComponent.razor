    private async Task RegisterUserAsync()
    {
        try
        {
            _isLoading = true;
            _registrationError = string.Empty;
            
            // Step 1: Validate registration data first (without creating the user)
            var validationRequest = new ValidateRegistrationRequest
            {
                Username = _registrationModel.Username,
                Email = _registrationModel.Email,
                Password = _registrationModel.Password,
                Token = _useToken ? _tokenValue : null,
                AppId = AppId,
                PricingModelId = DefaultPricingModelId
            };

            var validationResponse = await GetHttpClient().PostAsJsonAsync("api/userregistration/validate", validationRequest);
            
            if (!validationResponse.IsSuccessStatusCode)
            {
                _registrationError = "Unable to validate registration. Please try again.";
                return;
            }

            var validation = await validationResponse.Content.ReadFromJsonAsync<ValidationResponse>();
            
            if (validation == null || !validation.IsValid)
            {
                _registrationError = validation?.ErrorMessage ?? "Validation failed. Please check your information.";
                return;
            }

            _validationResponse = validation;

            // Step 2: Check for registration disclaimers
            try
            {
                var disclaimerResponse = await GetHttpClient().GetFromJsonAsync<PendingDisclaimersResponse>(
                    $"api/disclaimeracceptance/pending/{AppId}?showOn=registration");

                if (disclaimerResponse?.HasPendingDisclaimers == true && disclaimerResponse.Disclaimers.Any())
                {
                    _registrationDisclaimers = disclaimerResponse.Disclaimers;
                    _showRegistrationDisclaimers = true;
                    Logger.LogInformation("Registration disclaimers found: {Count}", _registrationDisclaimers.Count);
                    return;
                }
            }
            catch (Exception disclaimerEx)
            {
                Logger.LogWarning(disclaimerEx, "Failed to load registration disclaimers, continuing without them");
            }

            // Step 3: Determine if payment is required
            bool requiresPayment = validation.RequiresPayment;

            // Update pricing details from validation response
            if (requiresPayment)
            {
                _requiresPayment = true;
                _pricingDetails = new PricingDetails
                {
                    PlanName = validation.PricingModelName,
                    PriceAmount = validation.PriceAmount ?? 0,
                    Currency = validation.Currency ?? "USD",
                    IsSubscription = validation.IsSubscription
                };

                // Store pending registration state - we'll complete registration after payment
                _registrationPending = true;
                _currentStep = 3;

                // Create a temporary registration response with payment info for the PaymentComponent
                _registrationResponse = new RegistrationSuccessResponse
                {
                    Success = true,
                    RequiresPaymentSetup = true,
                    IsSubscription = validation.IsSubscription,
                    PaymentAppId = validation.PaymentAppId ?? AppId,
                    PricingModelId = validation.PricingModelId,
                    PricingModelName = validation.PricingModelName,
                    GrantedApps = validation.GrantedApps
                };

                Logger.LogInformation("Registration validated, payment required. Deferring user creation until payment completes.");
                return;
            }

            // Step 4: No payment required - complete registration immediately
            await CompleteRegistrationAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during registration");
            _registrationError = "An error occurred during registration. Please try again.";
            await OnError.InvokeAsync(ex.Message);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Called when user accepts registration disclaimers. Proceeds to payment or completes registration.
    /// </summary>
    private async Task HandleRegistrationDisclaimersAccepted(List<DisclaimerAcceptanceResult> acceptances)
    {
        _disclaimerAcceptances = acceptances;
        _showRegistrationDisclaimers = false;
        Logger.LogInformation("Registration disclaimers accepted: {Count}", acceptances.Count);

        // Continue to payment if required, otherwise complete registration
        if (_validationResponse?.RequiresPayment == true)
        {
            _requiresPayment = true;
            _pricingDetails = new PricingDetails
            {
                PlanName = _validationResponse.PricingModelName,
                PriceAmount = _validationResponse.PriceAmount ?? 0,
                Currency = _validationResponse.Currency ?? "USD",
                IsSubscription = _validationResponse.IsSubscription
            };

            _registrationPending = true;
            _currentStep = 3;

            _registrationResponse = new RegistrationSuccessResponse
            {
                Success = true,
                RequiresPaymentSetup = true,
                IsSubscription = _validationResponse.IsSubscription,
                PaymentAppId = _validationResponse.PaymentAppId ?? AppId,
                PricingModelId = _validationResponse.PricingModelId,
                PricingModelName = _validationResponse.PricingModelName,
                GrantedApps = _validationResponse.GrantedApps
            };
        }
        else
        {
            await CompleteRegistrationAsync();
        }
    }

