    private async Task SkipPaymentAsync()
    {
        try
        {
            // If registration was pending (deferred until payment), complete it now
            if (_registrationPending)
            {
                Logger.LogInformation("Registration was pending. Completing user registration (payment skipped).");
                await CompleteRegistrationAsync();
                
                if (!_registrationSuccessful)
                {
                    // Registration failed - stay on payment screen to retry or show error
                    Logger.LogError("Registration failed when payment was skipped.");
                    return;
                }
            }

            // Only call the skip endpoint if we have a UserId (registration completed)
            if (!string.IsNullOrEmpty(_registrationResponse?.UserId))
            {
                var skipRequest = new SkipPaymentRequest
                {
                    UserId = _registrationResponse.UserId,
                    RegistrationToken = _tokenValue,
                    Reason = "User chose to skip during registration"
                };

                await GetHttpClient().PostAsJsonAsync("api/registrationpayment/skip", skipRequest);
            }

            _paymentSkipped = true;
            _registrationSuccessful = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error skipping payment (continuing anyway)");
            _paymentSkipped = true;
            _registrationSuccessful = true;
        }
        
        StateHasChanged();
        
        if (AutoLogin)
        {
            await PerformAutoLoginAsync();
        }
    }

    private async Task PerformAutoLoginAsync()
    {
        try
        {
            _isAutoLoggingIn = true;
            _autoLoginError = string.Empty;
            StateHasChanged();

            var loginRequest = new LoginRequest
            {
                Username = _registrationModel.Username,
                Email = _registrationModel.Email,
                Password = _registrationModel.Password,
                AppId = AppId,
                Platform = "Web",
                DeviceInfo = "Browser"
            };

            var authResponse = await AuthService.LoginAsync(loginRequest);
            
            if (authResponse != null && !string.IsNullOrEmpty(authResponse.JwtToken))
            {
                _autoLoginComplete = true;
                Logger.LogInformation("Auto-login successful for user {Email}", _registrationModel.Email);
                
                await OnAutoLoginSuccess.InvokeAsync(authResponse);
                
                if (!string.IsNullOrEmpty(RedirectUrl))
                {
                    await JSRuntime.InvokeVoidAsync("eval", $"window.location.href = '{RedirectUrl}'");
                }
            }
            else
            {
                _autoLoginError = "Auto-login completed but no session was created. Please log in manually.";
                Logger.LogWarning("Auto-login returned no JWT token for user {Email}", _registrationModel.Email);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Auto-login failed for user {Email}", _registrationModel.Email);
            _autoLoginError = "Could not log you in automatically. Please use the login page to sign in.";
            await OnError.InvokeAsync($"Auto-login failed: {ex.Message}");
        }
        finally
        {
            _isAutoLoggingIn = false;
            StateHasChanged();
        }
    }

