    /// <summary>
    /// Completes the user registration by calling the API to create the user.
    /// Called either directly (when no payment required) or after successful payment.
    /// </summary>
    private async Task CompleteRegistrationAsync()
    {
        try
        {
            _isLoading = true;
            _registrationError = string.Empty;
            
            HttpResponseMessage response;
            
            // Use token-based registration if a valid token was provided (even when optional)
            if (_useToken && !string.IsNullOrEmpty(_tokenValue))
            {
                // Token-based registration
                var registrationRequest = new TokenRegistrationRequest
                {
                    Token = _tokenValue,
                    FirstName = _registrationModel.FirstName,
                    LastName = _registrationModel.LastName,
                    Email = _registrationModel.Email,
                    Password = _registrationModel.Password,
                    AppId = AppId,
                    Platform = "Web",
                    DeviceInfo = "Browser",
                    Username = _registrationModel.Username,
                    DisclaimerAcceptances = _disclaimerAcceptances
                };

                response = await GetHttpClient().PostAsJsonAsync("api/userregistration/register-with-token", registrationRequest);
            }
            else
            {
                // Open registration (without token)
                var registrationRequest = new OpenRegistrationRequest
                {
                    FirstName = _registrationModel.FirstName,
                    LastName = _registrationModel.LastName,
                    Email = _registrationModel.Email,
                    Password = _registrationModel.Password,
                    AppId = AppId,
                    Platform = "Web",
                    DeviceInfo = "Browser",
                    Username = _registrationModel.Username,
                    PricingModelId = DefaultPricingModelId,
                    DisclaimerAcceptances = _disclaimerAcceptances
                };

                response = await GetHttpClient().PostAsJsonAsync("api/userregistration/register", registrationRequest);
            }
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegistrationSuccessResponse>();
                
                if (result?.Success == true)
                {
                    _registrationResponse = result;
                    _registrationPending = false;
                    _registrationSuccessful = true;
                    
                    await OnRegistrationSuccess.InvokeAsync(new RegistrationSuccessEventArgs
                    {
                        UserId = result.UserId,
                        Email = _registrationModel.Email,
                        RequiresStripeSetup = result.RequiresStripeSetup,
                        RequiresPaymentSetup = result.RequiresPaymentSetup,
                        IsSubscription = result.IsSubscription
                    });
                    
                    // Trigger auto-login if enabled
                    if (AutoLogin)
                    {
                        await PerformAutoLoginAsync();
                    }
                }
                else
                {
                    _registrationError = result?.Message ?? "Registration failed. Please try again.";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Registration failed with status {StatusCode}. Response: {ErrorContent}", 
                    response.StatusCode, errorContent);
                
                try
                {
                    var errorResult = System.Text.Json.JsonSerializer.Deserialize<RegistrationSuccessResponse>(
                        errorContent, 
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    
                    if (!string.IsNullOrEmpty(errorResult?.Message))
                    {
                        _registrationError = errorResult.Message;
                    }
                    else
                    {
                        _registrationError = $"Registration failed: {response.StatusCode}";
                    }
                }
                catch (System.Text.Json.JsonException)
                {
                    if (!string.IsNullOrWhiteSpace(errorContent) && errorContent.Length < 500)
                    {
                        _registrationError = $"Registration failed: {errorContent}";
                    }
                    else
                    {
                        _registrationError = $"Registration failed: {response.StatusCode}";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error completing registration");
            _registrationError = "An error occurred during registration. Please try again.";
            await OnError.InvokeAsync(ex.Message);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

