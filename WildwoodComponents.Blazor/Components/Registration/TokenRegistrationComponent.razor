    private async Task HandlePaymentSuccess(PaymentSuccessEventArgs args)
    {
        Logger.LogInformation("Payment completed: TransactionId={TransactionId}, PaymentIntentId={PaymentIntentId}", 
            args.TransactionId, args.PaymentIntentId);
        
        // Store transaction IDs for linking after registration
        _pendingPaymentTransactionId = args.TransactionId;
        _pendingPaymentIntentId = args.PaymentIntentId;
        
        // If registration was pending (deferred until payment), complete it now
        if (_registrationPending)
        {
            Logger.LogInformation("Registration was pending. Completing user registration after successful payment.");
            await CompleteRegistrationAsync();
            
            if (!_registrationSuccessful)
            {
                // Registration failed after payment - this is a problem
                Logger.LogError("Registration failed after successful payment. TransactionId={TransactionId}", args.TransactionId);
                return;
            }
            
            // Link the payment transaction to the newly created user
            await LinkPaymentTransactionToUserAsync();
        }
        
        _paymentComplete = true;
        _registrationSuccessful = true;
        StateHasChanged();
        
        if (AutoLogin)
        {
            await PerformAutoLoginAsync();
        }
    }

    /// <summary>
    /// Links a pending payment transaction to the newly registered user.
    /// Called after CompleteRegistrationAsync succeeds when payment was made before registration.
    /// </summary>
    private async Task LinkPaymentTransactionToUserAsync()
    {
        // Determine which transaction ID to use for linking
        var externalTransactionId = _pendingPaymentIntentId ?? _pendingPaymentTransactionId;
        var userId = _registrationResponse?.UserId;
        
        if (string.IsNullOrEmpty(externalTransactionId))
        {
            Logger.LogWarning("No payment transaction ID available to link to user");
            return;
        }
        
        if (string.IsNullOrEmpty(userId))
        {
            Logger.LogWarning("No user ID available to link payment transaction to");
            return;
        }
        
        try
        {
            Logger.LogInformation("Linking payment transaction {ExternalTransactionId} to user {UserId}",
                externalTransactionId, userId);
            
            var linked = await PaymentProviderService.LinkTransactionToUserAsync(
                externalTransactionId, 
                userId,
                _tokenInfo?.CompanyClientId);
            
            if (linked)
            {
                Logger.LogInformation("Successfully linked payment transaction {ExternalTransactionId} to user {UserId}",
                    externalTransactionId, userId);
            }
            else
            {
                Logger.LogWarning("Failed to link payment transaction {ExternalTransactionId} to user {UserId}. " +
                    "The transaction was created but may not be associated with the user in the database.",
                    externalTransactionId, userId);
            }
        }
        catch (Exception ex)
        {
            // Log but don't fail registration - the payment was still successful
            Logger.LogError(ex, "Error linking payment transaction {ExternalTransactionId} to user {UserId}. " +
                "Registration completed successfully but transaction link failed.",
                externalTransactionId, userId);
        }
        finally
        {
            // Clear the pending transaction IDs
            _pendingPaymentTransactionId = null;
            _pendingPaymentIntentId = null;
        }
    }

