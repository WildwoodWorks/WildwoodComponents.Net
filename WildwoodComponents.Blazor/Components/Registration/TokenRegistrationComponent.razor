    private string FormatPrice(decimal amount)
    {
        var currency = _pricingDetails?.Currency ?? "USD";
        return currency switch
        {
            "USD" => $"${amount:F2}",
            "EUR" => $"�{amount:F2}",
            "GBP" => $"�{amount:F2}",
            _ => $"{currency} {amount:F2}"
        };
    }

    /// <summary>
    /// Gets a user-friendly display name for the pricing plan.
    /// Returns "Pricing" for generic or missing plan names.
    /// </summary>
    private string GetPricingDisplayName()
    {
        var planName = _pricingDetails?.PlanName ?? _registrationResponse?.PricingModelName;
        
        // Filter out generic names and return "Pricing" instead
        if (string.IsNullOrWhiteSpace(planName) || 
            planName.Equals("Default Pricing", StringComparison.OrdinalIgnoreCase) ||
            planName.Equals("Default", StringComparison.OrdinalIgnoreCase))
        {
            return "Pricing";
        }
        
        return planName;
    }

