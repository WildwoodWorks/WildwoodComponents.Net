@using WildwoodComponents.Blazor.Models
@using WildwoodComponents.Blazor.Services
@using WildwoodComponents.Blazor.Components.Base
@using Microsoft.Extensions.Logging
@inherits BaseWildwoodComponent
@inject ISecureMessagingService MessagingService

<div class="@GetRootCssClasses() secure-messaging-container">
    <!-- Header -->
    <div class="messaging-header">
        <div class="messaging-title">
            @if (CurrentThread != null)
            {
                <h3>@CurrentThread.Subject</h3>
                <div class="thread-info">
                    <span class="participant-count">@CurrentThread.Participants.Count participants</span>
                    @if (CurrentThread.ThreadType != ThreadType.Direct)
                    {
                        <span class="thread-type badge">@CurrentThread.ThreadType</span>
                    }
                </div>
            }
            else
            {
                <h3>Secure Messaging</h3>
                <span class="subtitle">@Settings.CompanyAppId</span>
            }
        </div>
        <div class="messaging-controls">
            @if (CurrentThread != null)
            {
                <button @onclick="ShowParticipants" class="btn-icon" title="Participants">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63A2.996 2.996 0 0 0 17.06 6H16c-1.65 0-3 1.35-3 3v1h2v7.5c0 .28.22.5.5.5s.5-.22.5-.5V13h2v9h-2z"/>
                        <path d="M8 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zM6 18v-6h2.5l-2.54-7.63A2.996 2.996 0 0 0 3.06 6H2c-1.65 0-3 1.35-3 3v1h2v7.5c0 .28.22.5.5.5s.5-.22.5-.5V13h2v9H6z"/>
                    </svg>
                </button>
                
                <button @onclick="ShowThreadSettings" class="btn-icon" title="Thread Settings">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                    </svg>
                </button>
            }
            
            <button @onclick="ShowThreadList" class="btn-icon" title="All Threads">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
                </svg>
            </button>
        </div>
    </div>

    <div class="messaging-content">
        <!-- Thread List Sidebar -->
        @if (ShowSidebar)
        {
            <div class="thread-sidebar">
                <div class="sidebar-header">
                    <h4>Conversations</h4>
                    <button @onclick="ShowNewThreadDialog" class="btn-new-thread">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                        New
                    </button>
                </div>
                
                <!-- Search Threads -->
                <div class="thread-search">
                    <input @bind="threadSearchTerm" @oninput="OnThreadSearchInput" 
                           placeholder="Search conversations..." class="search-input" />
                </div>
                
                <!-- Thread List -->
                <div class="thread-list">
                    @if (FilteredThreads.Any())
                    {
                        @foreach (var thread in FilteredThreads)
                        {
                            <div class="thread-item @(thread.Id == CurrentThreadId ? "active" : "")" 
                                 @onclick="() => SelectThread(thread.Id)">
                                <div class="thread-avatar">
                                    @if (thread.ThreadType == ThreadType.Direct && thread.Participants.Count == 2)
                                    {
                                        var otherParticipant = thread.Participants.FirstOrDefault(p => p.UserId != CurrentUserId);
                                        @if (!string.IsNullOrEmpty(otherParticipant?.Avatar))
                                        {
                                            <img src="@otherParticipant.Avatar" alt="@otherParticipant.UserName" />
                                        }
                                        else
                                        {
                                            <div class="avatar-placeholder">@GetInitials(otherParticipant?.UserName ?? "")</div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="group-avatar">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63A2.996 2.996 0 0 0 17.06 6H16c-1.65 0-3 1.35-3 3v1h2v7.5c0 .28.22.5.5.5s.5-.22.5-.5V13h2v9h-2z"/>
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div class="thread-content">
                                    <div class="thread-header">
                                        <span class="thread-name">@GetThreadDisplayName(thread)</span>
                                        <span class="thread-time">@FormatTime(thread.LastActivity)</span>
                                    </div>
                                    <div class="thread-preview">
                                        @if (!string.IsNullOrEmpty(thread.LastMessagePreview))
                                        {
                                            <span class="last-message">@thread.LastMessagePreview</span>
                                        }
                                        else
                                        {
                                            <span class="no-messages">No messages yet</span>
                                        }
                                    </div>
                                </div>
                                @if (thread.UnreadCount > 0)
                                {
                                    <div class="unread-badge">@thread.UnreadCount</div>
                                }
                            </div>
                        }
                    }
                    else if (IsLoadingThreads)
                    {
                        <div class="loading-placeholder">Loading conversations...</div>
                    }
                    else
                    {
                        <div class="empty-threads">
                            <p>No conversations found</p>
                            <button @onclick="ShowNewThreadDialog" class="btn-primary">Start a conversation</button>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Main Chat Area -->
        <div class="chat-area @(ShowSidebar ? "with-sidebar" : "full-width")">
            @if (CurrentThread != null)
            {
                <!-- Messages Container -->
                <div class="messages-container" @ref="messagesContainer">
                    @if (Messages.Any())
                    {
                        @foreach (var message in Messages)
                        {
                            <div class="message @GetMessageClass(message)" data-message-id="@message.Id">
                                <!-- Message Avatar -->
                                <div class="message-avatar">
                                    @if (!string.IsNullOrEmpty(message.SenderAvatar))
                                    {
                                        <img src="@message.SenderAvatar" alt="@message.SenderName" />
                                    }
                                    else
                                    {
                                        <div class="avatar-placeholder">@GetInitials(message.SenderName)</div>
                                    }
                                </div>

                                <!-- Message Content -->
                                <div class="message-content">
                                    <div class="message-header">
                                        <span class="sender-name">@message.SenderName</span>
                                        <span class="message-time">@message.CreatedAt.ToString("MMM d, h:mm tt")</span>
                                        @if (message.IsEdited)
                                        {
                                            <span class="edited-indicator">(edited)</span>
                                        }
                                    </div>

                                    <!-- Reply Context -->
                                    @if (!string.IsNullOrEmpty(message.ReplyToMessageId))
                                    {
                                        var replyToMessage = Messages.FirstOrDefault(m => m.Id == message.ReplyToMessageId);
                                        @if (replyToMessage != null)
                                        {
                                            <div class="reply-context" @onclick="() => ScrollToMessage(message.ReplyToMessageId)">
                                                <span class="reply-sender">@replyToMessage.SenderName</span>
                                                <span class="reply-content">@GetMessagePreview(replyToMessage.Content)</span>
                                            </div>
                                        }
                                    }

                                    <!-- Message Text -->
                                    <div class="message-text">
                                        @if (message.IsDeleted)
                                        {
                                            <span class="deleted-message">This message was deleted</span>
                                        }
                                        else
                                        {
                                            @((MarkupString)FormatMessageContent(message.Content))
                                        }
                                    </div>

                                    <!-- Attachments -->
                                    @if (message.Attachments.Any())
                                    {
                                        <div class="message-attachments">
                                            @foreach (var attachment in message.Attachments)
                                            {
                                                <div class="attachment @GetAttachmentClass(attachment.ContentType)">
                                                    @if (IsImageAttachment(attachment.ContentType) && !string.IsNullOrEmpty(attachment.ThumbnailUrl))
                                                    {
                                                        <img src="@attachment.ThumbnailUrl" alt="@attachment.FileName" @onclick="() => ViewAttachment(attachment)" />
                                                    }
                                                    else
                                                    {
                                                        <div class="file-attachment" @onclick="() => DownloadAttachment(attachment)">
                                                            <div class="file-icon">📄</div>
                                                            <div class="file-info">
                                                                <div class="file-name">@attachment.FileName</div>
                                                                <div class="file-size">@FormatFileSize(attachment.FileSize)</div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Reactions -->
                                    @if (message.Reactions.Any())
                                    {
                                        <div class="message-reactions">
                                            @foreach (var reactionGroup in message.Reactions.GroupBy(r => r.Emoji))
                                            {
                                                <div class="reaction @(HasUserReacted(message.Id, reactionGroup.Key) ? "user-reacted" : "")"
                                                     @onclick="() => ToggleReaction(message.Id, reactionGroup.Key)">
                                                    <span class="reaction-emoji">@reactionGroup.Key</span>
                                                    <span class="reaction-count">@reactionGroup.Count()</span>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Message Actions -->
                                    @if (message.SenderId == CurrentUserId && !message.IsDeleted)
                                    {
                                        <div class="message-actions">                                            <button @onclick="() => StartEditMessage(message)" class="action-btn" title="Edit">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                                </svg>
                                            </button>
                                            <button @onclick="() => DeleteMessage(message.Id)" class="action-btn delete" title="Delete">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                                </svg>
                                            </button>
                                        </div>
                                    }
                                </div>

                                <!-- Quick Actions -->
                                <div class="message-quick-actions">
                                    <button @onclick="() => StartReply(message)" class="quick-action" title="Reply">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M10 9V5l-7 7 7 7v-4.1c5 0 8.5 1.6 11 5.1-1-5-4-10-11-11z"/>
                                        </svg>
                                    </button>
                                    @if (Settings.EnableReactions)
                                    {
                                        <button @onclick="() => ShowEmojiPicker(message.Id)" class="quick-action" title="Add Reaction">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
                                            </svg>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else if (IsLoadingMessages)
                    {
                        <div class="loading-messages">Loading messages...</div>
                    }
                    else
                    {
                        <div class="no-messages">
                            <h4>Welcome to @CurrentThread.Subject</h4>
                            <p>This is the beginning of your conversation.</p>
                        </div>
                    }

                    <!-- Typing Indicators -->
                    @if (TypingUsers.Any())
                    {
                        <div class="typing-indicators">
                            @foreach (var typingUser in TypingUsers)
                            {
                                <div class="typing-indicator">
                                    <span class="typing-user">@typingUser.UserName</span> is typing
                                    <div class="typing-dots">
                                        <span></span>
                                        <span></span>
                                        <span></span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Message Input Area -->
                <div class="message-input-area">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="error-banner">
                            @ErrorMessage
                            <button @onclick="ClearError" class="error-close">×</button>
                        </div>
                    }

                    @if (ReplyToMessage != null)
                    {
                        <div class="reply-preview">
                            <div class="reply-content">
                                <span class="reply-to">Replying to @ReplyToMessage.SenderName</span>
                                <span class="reply-text">@GetMessagePreview(ReplyToMessage.Content)</span>
                            </div>
                            <button @onclick="CancelReply" class="cancel-reply">×</button>
                        </div>
                    }

                    @if (EditingMessage != null)
                    {
                        <div class="edit-preview">
                            <span class="edit-label">Editing message</span>
                            <button @onclick="CancelEdit" class="cancel-edit">×</button>
                        </div>
                    }

                    <!-- File Upload Preview -->
                    @if (PendingAttachments.Any())
                    {
                        <div class="attachment-preview">
                            @foreach (var attachment in PendingAttachments)
                            {
                                <div class="pending-attachment">
                                    <div class="attachment-info">
                                        <span class="filename">@attachment.FileName</span>
                                        <span class="filesize">@FormatFileSize(attachment.FileSize)</span>
                                    </div>
                                    @if (attachment.IsUploading)
                                    {
                                        <div class="upload-progress">
                                            <div class="progress-bar" style="width: @(attachment.UploadProgress)%"></div>
                                        </div>
                                    }
                                    <button @onclick="() => RemovePendingAttachment(attachment.Id)" class="remove-attachment">×</button>
                                </div>
                            }
                        </div>
                    }

                    <div class="input-container">
                        <div class="input-actions">
                            @if (Settings.EnableFileUploads)
                            {
                                <button @onclick="ShowFileUpload" class="input-action" title="Attach file">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5a2.5 2.5 0 0 1 5 0v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5a2.5 2.5 0 0 0 5 0V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.31 2.69 6 6 6s6-2.69 6-6V6h-2.5z"/>
                                    </svg>
                                </button>
                            }
                        </div>

                        <textarea @bind="CurrentMessage" 
                                 @onkeypress="OnKeyPress"
                                 @oninput="OnInput"
                                 @onfocus="OnInputFocus"
                                 @onblur="OnInputBlur"
                                 placeholder="Type a message..." 
                                 class="message-input"
                                 rows="1"
                                 disabled="@IsLoading"
                                 maxlength="@Settings.MaxMessageLength"
                                 @ref="messageInput"></textarea>

                        <div class="send-actions">
                            @if (Settings.EnableReactions)
                            {
                                <button @onclick="ShowQuickEmojis" class="input-action" title="Quick emoji">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
                                    </svg>
                                </button>
                            }
                            
                            <button @onclick="SendMessage" 
                                    class="send-btn @(CanSendMessage ? "enabled" : "disabled")" 
                                    disabled="@(!CanSendMessage)"
                                    title="Send message">
                                @if (IsLoading)
                                {
                                    <div class="spinner"></div>
                                }
                                else
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(CurrentMessage))
                    {
                        <div class="input-counter">
                            @CurrentMessage.Length / @Settings.MaxMessageLength
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Welcome Screen -->
                <div class="welcome-screen">
                    <div class="welcome-content">
                        <h3>Welcome to Secure Messaging</h3>
                        <p>Select a conversation from the sidebar or start a new one to begin messaging.</p>
                        @if (!ShowSidebar)
                        {
                            <button @onclick="ShowThreadList" class="btn-primary">View Conversations</button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Hidden file input -->
<input type="file" @ref="fileInput" @onchange="OnFileSelected" style="display: none;" multiple 
       accept="@string.Join(",", CurrentThread?.Settings.AllowedFileTypes ?? new List<string>())" />

@code {
    [Parameter] public string CompanyAppId { get; set; } = string.Empty;
    [Parameter] public string? CurrentUserId { get; set; }
    [Parameter] public SecureMessagingSettings Settings { get; set; } = new();
    [Parameter] public EventCallback<SecureMessage> OnMessageSent { get; set; }
    [Parameter] public EventCallback<SecureMessage> OnMessageReceived { get; set; }
    [Parameter] public EventCallback<MessageThread> OnThreadCreated { get; set; }
    [Parameter] public EventCallback<MessageThread> OnThreadSelected { get; set; }

    private List<MessageThread> Threads = new();
    private List<MessageThread> FilteredThreads = new();
    private List<SecureMessage> Messages = new();
    private List<CompanyAppUser> CompanyUsers = new();
    private List<TypingIndicator> TypingUsers = new();
    private List<PendingAttachment> PendingAttachments = new();
    
    private MessageThread? CurrentThread;
    private SecureMessage? ReplyToMessage;
    private SecureMessage? EditingMessage;
    
    private string CurrentThreadId = string.Empty;
    private string CurrentMessage = string.Empty;
    private string threadSearchTerm = string.Empty;
    
    private bool ShowSidebar = true;
    private bool IsLoadingThreads = false;
    private bool IsLoadingMessages = false;
    private bool IsTyping = false;
    
    private ElementReference messagesContainer;
    private ElementReference messageInput;
    private ElementReference fileInput;
    
    private System.Timers.Timer? typingTimer;

    private bool CanSendMessage => !IsLoading && (!string.IsNullOrWhiteSpace(CurrentMessage) || PendingAttachments.Any()) && CurrentThread != null;

    protected override async Task OnComponentInitializedAsync()
    {
        if (string.IsNullOrEmpty(CompanyAppId))
        {
            await HandleErrorAsync(new ArgumentException("CompanyAppId is required"), "Component initialization");
            return;
        }

        Settings.CompanyAppId = CompanyAppId;

        // Set up messaging service
        if (!string.IsNullOrEmpty(Settings.ApiBaseUrl))
        {
            MessagingService.SetApiBaseUrl(Settings.ApiBaseUrl);
        }

        await ExecuteAsync(async () =>
        {
            await LoadThreads();
            await LoadCompanyUsers();
        }, "Loading initial data");

        // Set up event handlers
        MessagingService.OnMessageReceived += HandleMessageReceived;
        MessagingService.OnTypingChanged += HandleTypingChanged;
        MessagingService.OnUserStatusChanged += HandleUserStatusChanged;
        MessagingService.OnThreadUpdated += HandleThreadUpdated;
    }

    protected override async Task OnComponentRenderedAsync()
    {
        if (Settings.AutoScrollToBottom && Messages.Any())
        {
            await ScrollToBottom();
        }
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            MessagingService.OnMessageReceived -= HandleMessageReceived;
            MessagingService.OnTypingChanged -= HandleTypingChanged;
            MessagingService.OnUserStatusChanged -= HandleUserStatusChanged;
            MessagingService.OnThreadUpdated -= HandleThreadUpdated;
            
            typingTimer?.Dispose();
        }
        base.Dispose(disposing);
    }

    // Event Handlers
    private async void HandleMessageReceived(object? sender, SecureMessage message)
    {
        if (message.ThreadId == CurrentThreadId)
        {
            Messages.Add(message);
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();
        }
        await OnMessageReceived.InvokeAsync(message);
    }

    private async void HandleTypingChanged(object? sender, TypingIndicator typingIndicator)
    {
        if (typingIndicator.ThreadId == CurrentThreadId)
        {
            if (typingIndicator.IsVisible && typingIndicator.UserId != CurrentUserId)
            {
                var existing = TypingUsers.FirstOrDefault(t => t.UserId == typingIndicator.UserId);
                if (existing != null)
                {
                    existing.StartedAt = typingIndicator.StartedAt;
                }
                else
                {
                    TypingUsers.Add(typingIndicator);
                }
            }
            else
            {
                TypingUsers.RemoveAll(t => t.UserId == typingIndicator.UserId);
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleUserStatusChanged(object? sender, OnlineStatus status)
    {
        // Update user status in threads
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleThreadUpdated(object? sender, string threadId)
    {
        if (threadId == CurrentThreadId)
        {
            await LoadMessages(threadId);
        }
        await LoadThreads();
        await InvokeAsync(StateHasChanged);
    }

    // Core Methods
    private async Task LoadThreads()
    {
        try
        {
            IsLoadingThreads = true;
