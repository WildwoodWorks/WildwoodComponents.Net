    // Message Management
    private async Task SendMessage()
    {
        if (!CanSendMessage || CurrentThread == null)
            return;

        await ExecuteAsync(async () =>
        {
            var content = CurrentMessage.Trim();
            var messageType = PendingAttachments.Any() ? MessageType.File : MessageType.Text;
            
            // Stop typing indicator
            if (IsTyping)
            {
                await MessagingService.StopTypingAsync(CurrentThreadId);
                IsTyping = false;
            }

            SecureMessage sentMessage;
            
            if (EditingMessage != null)
            {
                // Edit existing message
                sentMessage = await MessagingService.EditMessageAsync(EditingMessage.Id, content);
                var existingMessage = Messages.FirstOrDefault(m => m.Id == EditingMessage.Id);
                if (existingMessage != null)
                {
                    existingMessage.Content = sentMessage.Content;
                    existingMessage.IsEdited = true;
                    existingMessage.UpdatedAt = sentMessage.UpdatedAt;
                }
                CancelEdit();
            }
            else
            {
                // Send new message
                sentMessage = await MessagingService.SendMessageAsync(
                    CurrentThreadId, 
                    content, 
                    messageType, 
                    ReplyToMessage?.Id
                );
                
                Messages.Add(sentMessage);
                
                // Handle file attachments
                foreach (var attachment in PendingAttachments.ToList())
                {
                    try
                    {
                        await MessagingService.UploadAttachmentAsync(CurrentThreadId, attachment);
                        PendingAttachments.Remove(attachment);
                    }
                    catch (Exception ex)
                    {
                        Logger?.LogError(ex, "Error uploading attachment {FileName}", attachment.FileName);
                    }
                }
            }

            await OnMessageSent.InvokeAsync(sentMessage);
            ClearMessageInput();
            await ScrollToBottom();
        }, "Sending message");
    }
    
    private async Task DeleteMessage(string messageId)
    {
        try
        {
            var success = await MessagingService.DeleteMessageAsync(messageId);
            if (success)
            {
                var message = Messages.FirstOrDefault(m => m.Id == messageId);
                if (message != null)
                {
                    message.IsDeleted = true;
                    message.Content = string.Empty;
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error deleting message {MessageId}", messageId);
            await HandleErrorAsync(ex, "Failed to delete message");
        }
    }

