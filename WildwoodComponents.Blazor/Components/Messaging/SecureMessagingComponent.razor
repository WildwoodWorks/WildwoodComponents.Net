    private string GetMessageClass(SecureMessage message)
    {
        var classes = new List<string>();
        
        if (message.SenderId == CurrentUserId)
            classes.Add("own-message");
        else
            classes.Add("other-message");
            
        if (message.IsDeleted)
            classes.Add("deleted");
            
        if (!string.IsNullOrEmpty(message.ReplyToMessageId))
            classes.Add("reply-message");
            
        return string.Join(" ", classes);
    }

    private string GetAttachmentClass(string contentType)
    {
        if (IsImageAttachment(contentType))
            return "image-attachment";
        else if (IsVideoAttachment(contentType))
            return "video-attachment";
        else
            return "file-attachment";
    }

    private bool IsImageAttachment(string contentType)
    {
        return contentType.StartsWith("image/");
    }

    private bool IsVideoAttachment(string contentType)
    {
        return contentType.StartsWith("video/");
    }

    private string GetThreadDisplayName(MessageThread thread)
    {
        if (thread.ThreadType == ThreadType.Direct && thread.Participants.Count == 2)
        {
            var otherParticipant = thread.Participants.FirstOrDefault(p => p.UserId != CurrentUserId);
            return otherParticipant?.UserName ?? "Unknown User";
        }
        return thread.Subject;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name))
            return "?";
            
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        else
            return parts[0][0].ToString().ToUpper();
    }

    private string FormatTime(DateTime dateTime)
    {
        var now = DateTime.UtcNow;
        var diff = now - dateTime;
        
        if (diff.TotalMinutes < 1)
            return "now";
        else if (diff.TotalHours < 1)
            return $"{(int)diff.TotalMinutes}m";
        else if (diff.TotalDays < 1)
            return $"{(int)diff.TotalHours}h";
        else if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays}d";
        else
            return dateTime.ToString("MMM d");
    }

    private string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return string.Format("{0:n1} {1}", number, suffixes[counter]);
    }

    private string GetMessagePreview(string content)
    {
        const int maxLength = 50;
        if (string.IsNullOrEmpty(content))
            return "";
            
        return content.Length > maxLength ? content[..maxLength] + "..." : content;
    }

