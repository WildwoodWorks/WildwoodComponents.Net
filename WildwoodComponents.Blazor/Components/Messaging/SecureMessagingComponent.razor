    private void ApplyThreadFilter()
    {
        if (string.IsNullOrWhiteSpace(threadSearchTerm))
        {
            FilteredThreads = Threads.ToList();
        }
        else
        {
            FilteredThreads = Threads.Where(t => 
                t.Subject.Contains(threadSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                t.Participants.Any(p => p.UserName.Contains(threadSearchTerm, StringComparison.OrdinalIgnoreCase))
            ).ToList();
        }
    }

