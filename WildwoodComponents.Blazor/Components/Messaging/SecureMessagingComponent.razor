    private async Task ToggleReaction(string messageId, string emoji)
    {
        try
        {
            var message = Messages.FirstOrDefault(m => m.Id == messageId);
            if (message == null) return;

            var userReaction = message.Reactions.FirstOrDefault(r => r.UserId == CurrentUserId && r.Emoji == emoji);
            
            if (userReaction != null)
            {
                // Remove reaction
                await MessagingService.RemoveReactionAsync(messageId, emoji);
                message.Reactions.Remove(userReaction);
            }
            else
            {
                // Add reaction
                await MessagingService.ReactToMessageAsync(messageId, emoji);
                message.Reactions.Add(new MessageReaction
                {
                    MessageId = messageId,
                    UserId = CurrentUserId ?? "",
                    UserName = "You",
                    Emoji = emoji,
                    CreatedAt = DateTime.UtcNow
                });
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Error toggling reaction");
        }
    }

    // Input Handling
    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (e.ShiftKey)
            {
                // Allow new line            return;
            }
            else
            {
                // Send message
                await SendMessage();
            }
        }
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        CurrentMessage = e.Value?.ToString() ?? "";
        
        if (Settings.EnableTypingIndicators && CurrentThread != null)
        {
            if (!string.IsNullOrWhiteSpace(CurrentMessage) && !IsTyping)
            {
                IsTyping = true;
                await MessagingService.StartTypingAsync(CurrentThreadId);
                StartTypingTimer();
            }
            else if (string.IsNullOrWhiteSpace(CurrentMessage) && IsTyping)
            {
                IsTyping = false;
                await MessagingService.StopTypingAsync(CurrentThreadId);
                StopTypingTimer();
            }
        }
        
        StateHasChanged();
    }

    private async Task OnInputFocus()
    {
        await Task.CompletedTask;
    }

    private async Task OnInputBlur()
    {
        if (IsTyping)
        {
            IsTyping = false;
            await MessagingService.StopTypingAsync(CurrentThreadId);
            StopTypingTimer();
        }
    }

    private void StartTypingTimer()
    {
        StopTypingTimer();
        typingTimer = new System.Timers.Timer(3000); // Stop typing after 3 seconds of inactivity
        typingTimer.Elapsed += async (sender, e) =>
        {
            if (IsTyping)
            {
                IsTyping = false;
                await MessagingService.StopTypingAsync(CurrentThreadId);
                StopTypingTimer();
                await InvokeAsync(StateHasChanged);
            }
        };
        typingTimer.Start();
    }

    private void StopTypingTimer()
    {
        typingTimer?.Stop();
        typingTimer?.Dispose();
        typingTimer = null;
    }

