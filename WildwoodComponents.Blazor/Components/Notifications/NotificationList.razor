@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

<div class="ww-notification-list-container @CssClass">
    <div class="ww-notification-inbox">
        <div class="ww-notification-inbox-header">
            <span class="ww-notification-inbox-title">Notifications</span>
            <div>
                <button type="button" class="ww-notification-inbox-refresh" @onclick="RefreshAsync">
                    Refresh
                </button>
                @if (ShowMarkAllRead)
                {
                    <button type="button" class="ww-notification-inbox-markall"
                            @onclick="MarkAllRead" disabled="@(_unreadCount == 0)">
                        Mark all read
                    </button>
                }
            </div>
        </div>

        @if (_notifications.Count == 0)
        {
            <div class="ww-notification-inbox-empty">@EmptyText</div>
        }
        else
        {
            <ul class="ww-notification-inbox-list">
                @foreach (var n in _notifications)
                {
                    <li class="ww-notification-inbox-item @(n.IsUnread ? "ww-notification-inbox-item-unread" : null)">
                        <div class="ww-notification-inbox-item-main" @onclick="() => OnItemClick(n)">
                            @if (n.IsUnread)
                            {
                                <span class="ww-notification-inbox-dot" aria-hidden="true"></span>
                            }
                            <div class="ww-notification-inbox-item-body">
                                @if (!string.IsNullOrEmpty(n.Title))
                                {
                                    <div class="ww-notification-inbox-item-title">@n.Title</div>
                                }
                                <div class="ww-notification-inbox-item-message">@n.Message</div>
                                <div class="ww-notification-inbox-item-time">@TimeAgo(n.CreatedAt)</div>
                            </div>
                        </div>
                        <div class="ww-notification-inbox-item-actions">
                            <button type="button" class="ww-notification-inbox-remove" title="Dismiss"
                                    @onclick="() => Remove(n)">&times;</button>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
