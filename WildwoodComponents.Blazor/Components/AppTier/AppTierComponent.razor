@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Blazor.Components.Authentication
@using WildwoodComponents.Blazor.Components.Payment
@using WildwoodComponents.Blazor.Models
@using WildwoodComponents.Blazor.Services
@inherits BaseWildwoodComponent

<div class="@GetRootCssClasses() app-tier-component">
    @if (IsLoading && ShowLoadingStates)
    {
        <div class="app-tier-loading text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">@(_loadingMessage ?? "Loading plans...")</p>
        </div>
    }
    else if (_currentStep == AppTierComponentStep.TierSelection)
    {
        <!-- Tier Selection -->
        <div class="tier-selection">
            @if (!string.IsNullOrEmpty(Title))
            {
                <h3 class="text-center mb-2">@Title</h3>
            }

            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <p class="text-center text-muted mb-4">@Subtitle</p>
            }

            <!-- Billing Cycle Toggle -->
            @if (ShowBillingToggle && HasMonthlyAndAnnualPricing())
            {
                <div class="ww-apptier-billing-toggle">
                    <span class="@(_selectedBillingCycle == "monthly" ? "ww-billing-active" : "")">Monthly</span>
                    <button type="button"
                            class="ww-toggle @(_selectedBillingCycle == "annually" ? "ww-toggle-on" : "")"
                            @onclick="@(() => SetBillingCycle(_selectedBillingCycle == "annually" ? "monthly" : "annually"))"
                            aria-label="Toggle annual billing">
                        <span class="ww-toggle-slider"></span>
                    </button>
                    <span class="@(_selectedBillingCycle == "annually" ? "ww-billing-active" : "")">
                        Annual
                        @{ var _maxDiscount = GetMaxAnnualDiscount(); }
                        @if (_maxDiscount > 0)
                        {
                            <span class="ww-badge ww-badge-success ww-badge-sm">Save @_maxDiscount%</span>
                        }
                    </span>
                </div>
            }

            <!-- Tier Cards Grid -->
            <div class="ww-tier-grid">
                @foreach (var tier in _tiers)
                {
                    var isCurrentPlan = IsTierCurrentPlan(tier);
                    var isPreSelected = IsTierPreSelected(tier);
                    var pricing = FindPricingForCycle(tier, _selectedBillingCycle);
                    var enterprise = IsEnterpriseTier(tier);

                    <div class="ww-tier-card @(isCurrentPlan ? "ww-tier-current" : "") @(isPreSelected && !isCurrentPlan ? "ww-tier-preselected" : "") @(tier.IsDefault && !isPreSelected && !isCurrentPlan ? "ww-tier-default" : "")">
                        @if (!isCurrentPlan && !string.IsNullOrEmpty(tier.CustomBadgeText))
                        {
                            <div class="ww-tier-default-badge">@tier.CustomBadgeText</div>
                        }
                        else if (isPreSelected && !isCurrentPlan)
                        {
                            <div class="ww-tier-preselected-badge">Your Selection</div>
                        }

                        <div class="ww-tier-header">
                            @if (!string.IsNullOrEmpty(tier.IconClass))
                            {
                                <span class="ww-tier-icon @tier.IconClass"></span>
                            }
                            <h3>@tier.Name</h3>
                            @if (!string.IsNullOrEmpty(tier.BadgeColor))
                            {
                                <span class="ww-badge ww-badge-@tier.BadgeColor">@tier.Status</span>
                            }
                            @if (tier.ShowPrice)
                            {
                                <div class="ww-tier-price">
                                    @if (enterprise)
                                    {
                                        <span class="ww-tier-price-amount">Custom</span>
                                    }
                                    else if (tier.IsFreeTier && pricing == null)
                                    {
                                        <span class="ww-tier-price-amount">Free</span>
                                    }
                                    else if (pricing != null)
                                    {
                                        <span class="ww-tier-price-amount">@FormatPrice(pricing.Price)</span>
                                        <span class="ww-tier-price-interval">/@(pricing.BillingFrequency?.ToLower() ?? "month")</span>
                                    }
                                </div>
                                @if (pricing != null && pricing.HasTrial)
                                {
                                    <div class="ww-tier-trial-badge">@pricing.TrialDays-day free trial</div>
                                }
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(tier.Description))
                        {
                            <p class="ww-tier-description">@tier.Description</p>
                        }

                        @* Features *@
                        @if (ShowFeatureComparison && tier.Features.Count > 0)
                        {
                            <ul class="ww-tier-features">
                                @foreach (var f in tier.Features)
                                {
                                    <li class="ww-tier-feature-item @(!f.IsEnabled ? "ww-tier-feature-disabled" : "")">
                                        @if (f.IsEnabled)
                                        {
                                            <svg class="ww-tier-feature-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <polyline points="20 6 9 17 4 12" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg class="ww-tier-feature-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <line x1="18" y1="6" x2="6" y2="18" />
                                                <line x1="6" y1="6" x2="18" y2="18" />
                                            </svg>
                                        }
                                        <span>@(string.IsNullOrEmpty(f.DisplayName) ? f.FeatureCode : f.DisplayName)</span>
                                    </li>
                                }
                            </ul>
                        }

                        @* Limits *@
                        @if (ShowLimits && tier.Limits.Count > 0)
                        {
                            <div class="ww-tier-limits">
                                @foreach (var l in tier.Limits)
                                {
                                    <div class="ww-tier-limit-item">
                                        <span class="ww-tier-limit-value">@l.MaxValueDisplay</span>
                                        <span class="ww-tier-limit-name">
                                            @(string.IsNullOrEmpty(l.DisplayName) ? l.LimitCode : l.DisplayName)
                                            @if (!string.IsNullOrEmpty(l.Unit))
                                            {
                                                <text> (@l.Unit)</text>
                                            }
                                        </span>
                                    </div>
                                }
                            </div>
                        }

                        <div class="ww-tier-footer">
                            @if (isCurrentPlan)
                            {
                                <span class="ww-badge ww-badge-success">Current Plan</span>
                            }
                            else if (tier.ShowContactButton && !string.IsNullOrEmpty(tier.ContactButtonUrl))
                            {
                                <a href="@tier.ContactButtonUrl"
                                   class="ww-btn @(tier.IsDefault ? "ww-btn-primary" : "ww-btn-outline") ww-btn-block"
                                   @(tier.ContactButtonUrl.StartsWith("http") ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                                    Contact Us
                                </a>
                            }
                            else if (enterprise && !string.IsNullOrEmpty(EnterpriseContactUrl))
                            {
                                <a href="@EnterpriseContactUrl"
                                   class="ww-btn ww-btn-outline ww-btn-block"
                                   @(EnterpriseContactUrl.StartsWith("http") ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                                    Contact Sales
                                </a>
                            }
                            else if (enterprise)
                            {
                                <button type="button" class="ww-btn ww-btn-outline ww-btn-block" @onclick="() => SelectTier(tier)">
                                    Contact Sales
                                </button>
                            }
                            else if (tier.ShowSubscribeButton)
                            {
                                <button type="button"
                                        class="ww-btn @(isPreSelected || tier.IsDefault ? "ww-btn-primary" : "ww-btn-outline") ww-btn-block"
                                        @onclick="() => SelectTier(tier)">
                                    @if (isPreSelected)
                                    {
                                        <text>Continue with This Plan</text>
                                    }
                                    else if (pricing != null && pricing.HasTrial)
                                    {
                                        <text>Start @pricing.TrialDays-Day Free Trial</text>
                                    }
                                    else if (tier.IsFreeTier && _currentSubscription != null && _currentSubscription.IsActive)
                                    {
                                        <text>Get Started Free</text>
                                    }
                                    else if (tier.IsFreeTier)
                                    {
                                        <text>Get Started</text>
                                    }
                                    else if (_currentSubscription != null && _currentSubscription.IsActive)
                                    {
                                        <text>Switch to @tier.Name</text>
                                    }
                                    else
                                    {
                                        <text>Subscribe</text>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Current Subscription Info -->
            @if (ShowCurrentPlan && _currentSubscription != null && _currentSubscription.IsActive)
            {
                <div class="current-subscription mt-4">
                    <div class="card">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h6 class="mb-1">Current Subscription</h6>
                                    <p class="mb-0">
                                        <strong>@_currentSubscription.TierName</strong>
                                        <span class="badge @(_currentSubscription.Status == "Trialing" ? "bg-info" : "bg-success") ms-2">@_currentSubscription.Status</span>
                                    </p>
                                    @if (_currentSubscription.CurrentPeriodEnd.HasValue)
                                    {
                                        <small class="text-muted">
                                            Renews: @_currentSubscription.CurrentPeriodEnd.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    }
                                    @if (_currentSubscription.Status == "Trialing" && _currentSubscription.TrialEndDate.HasValue)
                                    {
                                        <small class="text-muted">
                                            Trial ends: @_currentSubscription.TrialEndDate.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    }
                                    @if (!string.IsNullOrEmpty(_currentSubscription.PendingTierName))
                                    {
                                        <div class="mt-1">
                                            <span class="badge bg-info">
                                                Changing to @_currentSubscription.PendingTierName
                                                @if (_currentSubscription.PendingChangeDate.HasValue)
                                                {
                                                    <text> on @_currentSubscription.PendingChangeDate.Value.ToString("MMM dd")</text>
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-4 text-end">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="ShowCancelConfirmation">
                                        Cancel Subscription
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Add-Ons Section -->
            @if (ShowAddOns && _addOns.Count > 0)
            {
                <div class="ww-addon-section">
                    <h4 class="ww-addon-title">Add-Ons</h4>
                    <div class="ww-addon-grid">
                        @foreach (var addOn in _addOns)
                        {
                            var isSubscribed = IsAddOnSubscribed(addOn);
                            var isBundled = IsAddOnBundled(addOn);
                            var pricing = GetDefaultAddOnPricing(addOn);

                            <div class="ww-addon-card @(isSubscribed || isBundled ? "ww-addon-active" : "")">
                                <div class="ww-addon-body">
                                    <div class="ww-addon-header">
                                        @if (!string.IsNullOrEmpty(addOn.IconClass))
                                        {
                                            <span class="ww-addon-icon @addOn.IconClass"></span>
                                        }
                                        <span class="ww-addon-name">@addOn.Name</span>

                                        @if (isBundled)
                                        {
                                            <span class="ww-badge ww-badge-success ww-badge-sm">Included</span>
                                        }
                                        else if (isSubscribed)
                                        {
                                            <span class="ww-badge ww-badge-success ww-badge-sm">Active</span>
                                        }
                                    </div>

                                    @if (!string.IsNullOrEmpty(addOn.Description))
                                    {
                                        <p class="ww-addon-description">@addOn.Description</p>
                                    }

                                    @if (pricing != null && !isBundled)
                                    {
                                        <div class="ww-addon-price">
                                            <strong>@GetCurrencySymbol(Currency)@pricing.Price.ToString("N2")</strong>
                                            <span class="ww-addon-price-interval">/ @pricing.BillingFrequency.ToLower()</span>
                                        </div>
                                    }

                                    @if (addOn.Features.Count > 0)
                                    {
                                        <ul class="ww-addon-features">
                                            @foreach (var feature in addOn.Features)
                                            {
                                                <li class="ww-addon-feature-item">
                                                    <svg class="ww-tier-feature-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                        <polyline points="20 6 9 17 4 12" />
                                                    </svg>
                                                    @(string.IsNullOrEmpty(feature.DisplayName) ? feature.FeatureCode : feature.DisplayName)
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                                @if (!isBundled)
                                {
                                    <div class="ww-addon-footer">
                                        @if (isSubscribed)
                                        {
                                            <button class="ww-btn ww-btn-outline ww-btn-block ww-btn-sm" disabled>
                                                Subscribed
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="ww-btn ww-btn-outline ww-btn-block ww-btn-sm"
                                                    disabled="@(_currentSubscription == null || !_currentSubscription.IsActive || _isProcessing)"
                                                    @onclick="@(() => SubscribeToAddOn(addOn))">
                                                @if (_isProcessing)
                                                {
                                                    <text>Adding...</text>
                                                }
                                                else
                                                {
                                                    <text>Add to Plan</text>
                                                }
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (_currentStep == AppTierComponentStep.Registration)
    {
        <!-- Registration Step -->
        <div class="registration-step">
            <div class="mb-4">
                <button class="btn btn-link p-0" @onclick="BackToTierSelection">
                    <i class="bi bi-arrow-left me-2"></i>Back to plans
                </button>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-7">
                    <h4 class="text-center mb-2">Create Your Account</h4>
                    <p class="text-center text-muted mb-4">
                        Sign in or register to subscribe to the <strong>@_selectedTier?.Name</strong> plan.
                    </p>

                    <WildwoodComponents.Blazor.Components.Authentication.AuthenticationComponent
                        AppId="@AppId"
                        OnAuthenticationSuccess="HandleAuthenticationSuccess"
                        OnAuthenticationError="HandleAuthenticationError" />
                </div>
                <div class="col-md-5">
                    <!-- Selected Plan Summary -->
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">Selected Plan</h6>
                        </div>
                        <div class="card-body text-center">
                            @if (_selectedTier != null)
                            {
                                @if (!string.IsNullOrEmpty(_selectedTier.IconClass))
                                {
                                    <div class="tier-icon mb-2">
                                        <i class="@_selectedTier.IconClass" style="font-size: 2rem;"></i>
                                    </div>
                                }
                                <h5>@_selectedTier.Name</h5>
                                <div class="tier-price my-2">
                                    @if (_selectedTier.IsFreeTier)
                                    {
                                        <span class="price-amount">Free</span>
                                    }
                                    else if (_selectedPricing != null)
                                    {
                                        <span class="price-currency">@GetCurrencySymbol(Currency)</span>
                                        <span class="price-amount">@_selectedPricing.Price.ToString("N0")</span>
                                        <span class="price-period">@GetPricePeriod(_selectedBillingCycle)</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(_selectedTier.Description))
                                {
                                    <p class="text-muted small">@_selectedTier.Description</p>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_currentStep == AppTierComponentStep.Payment)
    {
        <!-- Payment Step -->
        <div class="payment-step">
            <div class="mb-4">
                <button class="btn btn-link p-0" @onclick="BackToTierSelection">
                    <i class="bi bi-arrow-left me-2"></i>Back to plans
                </button>
            </div>

            <div class="row">
                <div class="col-md-7">
                    <h4>Complete Your Subscription</h4>
                    <p class="text-muted">You're subscribing to the <strong>@_selectedTier?.Name</strong> plan.</p>

                    @if (_currentSubscription != null && _currentSubscription.IsActive)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            You are upgrading from <strong>@_currentSubscription.TierName</strong> to <strong>@_selectedTier?.Name</strong>.
                        </div>
                    }

                    <!-- PaymentComponent Integration -->
                    <PaymentComponent AppId="@AppId"
                                     Amount="@GetPaymentAmount()"
                                     Currency="@Currency"
                                     Description="@($"{_selectedTier?.Name} Subscription")"
                                     CustomerId="@CustomerId"
                                     CustomerEmail="@CustomerEmail"
                                     PricingModelId="@_selectedPricing?.PricingModelId"
                                     IsSubscription="true"
                                     ShowAmount="false"
                                     RequireBillingAddress="@RequireBillingAddress"
                                     OnPaymentSuccess="HandlePaymentSuccess"
                                     OnPaymentFailure="HandlePaymentFailure"
                                     OnCancel="BackToTierSelection" />
                </div>
                <div class="col-md-5">
                    <!-- Order Summary -->
                    <div class="order-summary card">
                        <div class="card-header">
                            <h6 class="mb-0">Order Summary</h6>
                        </div>
                        <div class="card-body">
                            @if (_selectedTier != null)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@_selectedTier.Name Plan</span>
                                    <span>@GetCurrencySymbol(Currency)@GetPaymentAmount().ToString("N2")</span>
                                </div>
                            }
                            @if (_selectedPricing != null)
                            {
                                <small class="text-muted d-block mb-2">
                                    Billed @_selectedPricing.BillingFrequencyLabel.ToLower()
                                </small>
                            }
                            <hr />
                            <div class="d-flex justify-content-between fw-bold">
                                <span>Total</span>
                                <span>@GetCurrencySymbol(Currency)@GetPaymentAmount().ToString("N2")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Selected Tier Features -->
                    @if (_selectedTier != null && _selectedTier.Features.Count > 0)
                    {
                        <div class="card mt-3">
                            <div class="card-header">
                                <h6 class="mb-0">What's Included</h6>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var feature in _selectedTier.Features)
                                    {
                                        @if (feature.IsEnabled)
                                        {
                                            <li class="mb-1">
                                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                @(string.IsNullOrEmpty(feature.DisplayName) ? feature.FeatureCode : feature.DisplayName)
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (_currentStep == AppTierComponentStep.Success)
    {
        <!-- Success -->
        <div class="tier-success text-center py-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>
            <h3>Welcome to @_selectedTier?.Name!</h3>
            @if (_currentSubscription?.TrialEndDate.HasValue == true)
            {
                <p class="text-muted">Your free trial has started!</p>
            }
            else
            {
                <p class="text-muted">Your subscription is now active.</p>
            }

            @if (_currentSubscription?.TrialEndDate.HasValue == true)
            {
                <div class="alert alert-info d-inline-block">
                    <i class="bi bi-calendar me-2"></i>
                    Your free trial ends on @_currentSubscription.TrialEndDate.Value.ToString("MMMM dd, yyyy")
                </div>
            }

            <div class="mt-4">
                @if (OnTierSelected.HasDelegate)
                {
                    <button class="btn btn-primary btn-lg" @onclick="HandleSuccessContinue">
                        Get Started
                    </button>
                }
                else
                {
                    <button class="btn btn-primary btn-lg" @onclick="BackToTierSelection">
                        View Plans
                    </button>
                }
            </div>
        </div>
    }
    else if (_currentStep == AppTierComponentStep.CancelConfirmation)
    {
        <!-- Cancel Confirmation -->
        <div class="cancel-confirmation">
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-exclamation-triangle text-warning" style="font-size: 3rem;"></i>
                    <h4 class="mt-3">Cancel Subscription?</h4>
                    <p class="text-muted">
                        Are you sure you want to cancel your <strong>@_currentSubscription?.TierName</strong> subscription?
                    </p>
                    @if (_currentSubscription?.CurrentPeriodEnd.HasValue == true)
                    {
                        <p class="text-muted">
                            You'll continue to have access until @_currentSubscription.CurrentPeriodEnd.Value.ToString("MMMM dd, yyyy").
                        </p>
                    }
                    <div class="mt-4">
                        <button class="btn btn-outline-secondary me-2" @onclick="BackToTierSelection">
                            Keep Subscription
                        </button>
                        <button class="btn btn-danger" @onclick="ConfirmCancellation" disabled="@_isProcessing">
                            @if (_isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Yes, Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Error Display -->
    @if (!string.IsNullOrEmpty(ErrorMessage) && EnableErrorHandling)
    {
        <div class="alert alert-danger mt-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @ErrorMessage
            <button type="button" class="btn-close float-end" @onclick="ClearError"></button>
        </div>
    }
</div>
