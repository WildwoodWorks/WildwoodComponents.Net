@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

@if (IsLoading)
{
    <div class="ww-tier-plans-loading text-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_tiers.Count == 0)
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No tier plans are configured for this application.
    </div>
}
else
{
    @if (ShowBillingToggle && HasMonthlyAndAnnualPricing())
    {
        <div class="ww-apptier-billing-toggle">
            <span class="@(_selectedBillingCycle == "monthly" ? "ww-billing-active" : "")">Monthly</span>
            <button type="button"
                    class="ww-toggle @(_selectedBillingCycle == "annually" ? "ww-toggle-on" : "")"
                    @onclick="@(() => SetBillingCycle(_selectedBillingCycle == "annually" ? "monthly" : "annually"))"
                    aria-label="Toggle annual billing">
                <span class="ww-toggle-slider"></span>
            </button>
            <span class="@(_selectedBillingCycle == "annually" ? "ww-billing-active" : "")">Annual</span>
        </div>
    }

    <div class="ww-tier-grid">
        @foreach (var tier in _tiers)
        {
            var isCurrent = IsTierCurrentPlan(tier);
            var pricing = FindPricingForCycle(tier, _selectedBillingCycle);
            var enterprise = IsEnterpriseTier(tier);

            <div class="ww-tier-card @(isCurrent ? "ww-tier-current" : "") @(tier.IsDefault && !isCurrent ? "ww-tier-default" : "")">
                @if (!string.IsNullOrEmpty(tier.CustomBadgeText) && !isCurrent)
                {
                    <div class="ww-tier-default-badge">@tier.CustomBadgeText</div>
                }

                <div class="ww-tier-header">
                    @if (!string.IsNullOrEmpty(tier.IconClass))
                    {
                        <span class="ww-tier-icon @tier.IconClass"></span>
                    }
                    <h3>@tier.Name</h3>
                    @if (!string.IsNullOrEmpty(tier.BadgeColor))
                    {
                        <span class="ww-badge ww-badge-@tier.BadgeColor">@tier.Status</span>
                    }
                    @if (tier.ShowPrice)
                    {
                        <div class="ww-tier-price">
                            @if (enterprise)
                            {
                                <span class="ww-tier-price-amount">Custom</span>
                            }
                            else if (tier.IsFreeTier && pricing == null)
                            {
                                <span class="ww-tier-price-amount">Free</span>
                            }
                            else if (pricing != null)
                            {
                                <span class="ww-tier-price-amount">@FormatPrice(pricing.Price)</span>
                                <span class="ww-tier-price-interval">/@(pricing.BillingFrequency?.ToLower() ?? "month")</span>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(tier.Description))
                {
                    <p class="ww-tier-description">@tier.Description</p>
                }

                @* Features *@
                @if (tier.Features.Count > 0)
                {
                    <ul class="ww-tier-features">
                        @foreach (var f in tier.Features)
                        {
                            <li class="ww-tier-feature-item @(!f.IsEnabled ? "ww-tier-feature-disabled" : "")">
                                @if (f.IsEnabled)
                                {
                                    <svg class="ww-tier-feature-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                }
                                else
                                {
                                    <svg class="ww-tier-feature-x" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>
                                }
                                <span>@(string.IsNullOrEmpty(f.DisplayName) ? f.FeatureCode : f.DisplayName)</span>
                            </li>
                        }
                    </ul>
                }

                @* Limits *@
                @if (tier.Limits.Count > 0)
                {
                    <div class="ww-tier-limits">
                        @foreach (var l in tier.Limits)
                        {
                            <div class="ww-tier-limit-item">
                                <span class="ww-tier-limit-value">@l.MaxValueDisplay</span>
                                <span class="ww-tier-limit-name">
                                    @(string.IsNullOrEmpty(l.DisplayName) ? l.LimitCode : l.DisplayName)
                                    @if (!string.IsNullOrEmpty(l.Unit))
                                    {
                                        <text> (@l.Unit)</text>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                }

                <div class="ww-tier-footer">
                    @if (isCurrent)
                    {
                        <span class="ww-badge ww-badge-success">Current Plan</span>
                    }
                    else if (tier.ShowContactButton && !string.IsNullOrEmpty(tier.ContactButtonUrl))
                    {
                        <a href="@tier.ContactButtonUrl"
                           class="ww-btn @(tier.IsDefault ? "ww-btn-primary" : "ww-btn-outline") ww-btn-block"
                           @(tier.ContactButtonUrl.StartsWith("http") ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                            Contact Us
                        </a>
                    }
                    else if (enterprise && !string.IsNullOrEmpty(EnterpriseContactUrl))
                    {
                        <a href="@EnterpriseContactUrl"
                           class="ww-btn ww-btn-outline ww-btn-block"
                           @(EnterpriseContactUrl.StartsWith("http") ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
                            Contact Sales
                        </a>
                    }
                    else if (enterprise)
                    {
                        <button type="button" class="ww-btn ww-btn-outline ww-btn-block"
                                @onclick="@(() => SelectTier(tier, null))">
                            Contact Sales
                        </button>
                    }
                    else if (tier.ShowSubscribeButton)
                    {
                        <button type="button"
                                class="ww-btn @(tier.IsDefault ? "ww-btn-primary" : "ww-btn-outline") ww-btn-block"
                                disabled="@_isProcessing"
                                @onclick="@(() => SelectTier(tier, pricing?.Id))">
                            @if (_isProcessing)
                            {
                                <text>Processing...</text>
                            }
                            else if (tier.IsFreeTier && _currentSubscription != null && _currentSubscription.IsActive)
                            {
                                <text>Get Started Free</text>
                            }
                            else if (tier.IsFreeTier)
                            {
                                <text>Get Started</text>
                            }
                            else if (_currentSubscription != null && _currentSubscription.IsActive)
                            {
                                <text>Switch to @tier.Name</text>
                            }
                            else
                            {
                                <text>Subscribe</text>
                            }
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}
