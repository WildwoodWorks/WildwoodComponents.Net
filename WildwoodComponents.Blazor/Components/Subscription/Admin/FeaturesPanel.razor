@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

@if (IsLoading)
{
    <div class="ww-features-loading text-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_features.Count == 0)
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No feature definitions are configured for this application.
    </div>
}
else
{
    <div class="ww-features-panel">
        <div class="ww-features-summary">
            <span class="ww-features-summary-icon">
                <i class="fas fa-check-circle"></i>
            </span>
            <span>@GetEnabledCount() of @_features.Count features enabled</span>
        </div>

        @foreach (var category in _categories)
        {
            var categoryFeatures = GetFeaturesForCategory(category);

            <div class="ww-features-category-card">
                <div class="ww-features-category-header">
                    <i class="fas fa-folder me-2"></i>@category
                </div>

                <div class="ww-features-category-body">
                    @foreach (var feature in categoryFeatures)
                    {
                        <div class="ww-feature-card @(feature.IsEnabled ? "ww-feature-card-enabled" : "ww-feature-card-locked")">
                            <span class="ww-feature-card-icon">
                                @if (feature.IsEnabled)
                                {
                                    <i class="fas fa-check-circle"></i>
                                }
                                else
                                {
                                    <i class="fas fa-lock"></i>
                                }
                            </span>
                            <div class="ww-feature-card-body">
                                <div class="ww-feature-card-name">
                                    @if (!string.IsNullOrEmpty(feature.IconClass))
                                    {
                                        <i class="@feature.IconClass me-1"></i>
                                    }
                                    @feature.DisplayName
                                </div>
                                @if (!string.IsNullOrEmpty(feature.Description))
                                {
                                    <div class="ww-feature-card-desc">@feature.Description</div>
                                }
                            </div>
                            <span class="badge @(feature.IsEnabled ? "bg-success" : "bg-secondary")">
                                @(feature.IsEnabled ? "Enabled" : "Locked")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
