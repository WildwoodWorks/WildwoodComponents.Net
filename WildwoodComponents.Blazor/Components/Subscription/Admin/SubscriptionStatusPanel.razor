@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

@if (IsLoading)
{
    <div class="ww-sub-status-loading text-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_subscription == null)
{
    <div class="ww-sub-status-empty">
        <div class="alert alert-info mb-0">
            <i class="fas fa-info-circle me-2"></i>No active subscription found.
        </div>
    </div>
}
else
{
    <div class="ww-sub-status-card card shadow-sm">
        <div class="card-body">
            <div class="ww-sub-status-title-row">
                <div class="ww-sub-status-title-left">
                    <h5 class="ww-sub-status-tier-name">
                        <i class="fas fa-layer-group me-2"></i>@_subscription.TierName
                    </h5>
                    <span class="badge @GetStatusBadgeClass(_subscription.Status)">@_subscription.Status</span>
                    @if (_subscription.IsFreeTier)
                    {
                        <span class="badge bg-secondary">Free</span>
                    }
                </div>
                @if (_subscription.IsActive && !_subscription.IsFreeTier)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="ShowCancelConfirmation">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                }
            </div>

            <div class="ww-sub-status-fields">
                <div class="ww-sub-status-field">
                    <div class="ww-sub-status-field-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="ww-sub-status-field-content">
                        <span class="ww-sub-status-field-label">Start Date</span>
                        <span class="ww-sub-status-field-value">@_subscription.StartDate.ToString("MMM d, yyyy")</span>
                    </div>
                </div>

                @if (_subscription.CurrentPeriodEnd.HasValue)
                {
                    <div class="ww-sub-status-field">
                        <div class="ww-sub-status-field-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="ww-sub-status-field-content">
                            <span class="ww-sub-status-field-label">Current Period Ends</span>
                            <span class="ww-sub-status-field-value">@_subscription.CurrentPeriodEnd.Value.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>
                }

                @if (_subscription.TrialEndDate.HasValue)
                {
                    <div class="ww-sub-status-field">
                        <div class="ww-sub-status-field-icon ww-sub-status-field-icon-trial">
                            <i class="fas fa-star"></i>
                        </div>
                        <div class="ww-sub-status-field-content">
                            <span class="ww-sub-status-field-label">Trial Ends</span>
                            <span class="ww-sub-status-field-value">@_subscription.TrialEndDate.Value.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>
                }

                @if (_subscription.GracePeriodEndDate.HasValue)
                {
                    <div class="ww-sub-status-field">
                        <div class="ww-sub-status-field-icon ww-sub-status-field-icon-grace">
                            <i class="fas fa-hourglass-half"></i>
                        </div>
                        <div class="ww-sub-status-field-content">
                            <span class="ww-sub-status-field-label">Grace Period Ends</span>
                            <span class="ww-sub-status-field-value text-warning">@_subscription.GracePeriodEndDate.Value.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_subscription.PendingTierName))
            {
                <div class="ww-sub-status-pending">
                    <i class="fas fa-clock me-2"></i>
                    <strong>Pending change:</strong> Switching to <strong>@_subscription.PendingTierName</strong>
                    @if (_subscription.PendingChangeDate.HasValue)
                    {
                        <span> on @_subscription.PendingChangeDate.Value.ToString("MMM d, yyyy")</span>
                    }
                </div>
            }
        </div>
    </div>

    @if (_showCancelConfirm)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Cancel Subscription</h5>
                        <button type="button" class="btn-close" @onclick="HideCancelConfirmation"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to cancel the <strong>@_subscription.TierName</strong> subscription?</p>
                        @if (!_subscription.IsFreeTier)
                        {
                            <p class="text-muted mb-0">The subscription will remain active until the end of the current billing period.</p>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideCancelConfirmation">Keep Subscription</button>
                        <button type="button" class="btn btn-danger" @onclick="ConfirmCancel">Confirm Cancellation</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
