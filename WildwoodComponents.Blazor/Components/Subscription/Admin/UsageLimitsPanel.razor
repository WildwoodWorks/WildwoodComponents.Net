@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

@if (IsLoading)
{
    <div class="ww-usage-loading text-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_limits.Count == 0)
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No usage limits are configured for this subscription.
    </div>
}
else
{
    <div class="ww-usage-limits-panel">
        <div class="ww-usage-limits-grid">
            @foreach (var limit in _limits)
            {
                var statusKey = (limit.IsHardBlocked || limit.IsExceeded) ? "danger"
                    : limit.IsAtWarningThreshold ? "warning"
                    : "success";

                <div class="ww-usage-card ww-usage-card-@statusKey">
                    <div class="ww-usage-card-header">
                        <div class="ww-usage-card-title">
                            <span class="ww-usage-card-icon ww-usage-card-icon-@statusKey">
                                @if (statusKey == "danger")
                                {
                                    <i class="fas fa-exclamation-circle"></i>
                                }
                                else if (statusKey == "warning")
                                {
                                    <i class="fas fa-exclamation-triangle"></i>
                                }
                                else
                                {
                                    <i class="fas fa-check-circle"></i>
                                }
                            </span>
                            <span class="ww-usage-card-name">@limit.DisplayName</span>
                        </div>
                        <span class="badge @GetBadgeClass(limit)">
                            @GetBadgeText(limit)
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(limit.Unit))
                    {
                        <span class="ww-usage-card-unit">@limit.Unit</span>
                    }

                    <div class="ww-usage-card-bar-wrapper">
                        <div class="ww-usage-card-bar">
                            <div class="ww-usage-card-bar-fill ww-bar-@statusKey"
                                 style="width: @(GetBarWidth(limit))%">
                            </div>
                        </div>
                    </div>

                    <div class="ww-usage-card-stats">
                        @if (limit.IsUnlimited)
                        {
                            <span class="ww-usage-card-count">@limit.CurrentUsage.ToString("N0") used</span>
                        }
                        else if (IsAdmin && IsEditingLimit(limit.LimitCode))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="ww-usage-card-count">@limit.CurrentUsage.ToString("N0") /</span>
                                <input type="number" class="form-control form-control-sm" style="width: 100px;"
                                       @bind="_editMaxValue" @bind:event="oninput"
                                       min="0" disabled="@_isProcessing" />
                                <button class="btn btn-sm btn-success" @onclick="@(() => SaveLimitMaxValue(limit.LimitCode))"
                                        disabled="@_isProcessing" title="Save">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelEditLimit"
                                        disabled="@_isProcessing" title="Cancel">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="ww-usage-card-count">
                                @limit.CurrentUsage.ToString("N0") / @limit.MaxValue.ToString("N0")
                            </span>
                            <span class="ww-usage-card-percent">@((int)Math.Round(limit.UsagePercent))%</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(limit.StatusMessage))
                    {
                        <div class="ww-usage-card-message">@limit.StatusMessage</div>
                    }

                    @if (IsAdmin && !IsEditingLimit(limit.LimitCode))
                    {
                        <div class="ww-usage-card-actions mt-2">
                            @if (!limit.IsUnlimited)
                            {
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => StartEditLimit(limit))"
                                        disabled="@_isProcessing" title="Edit max value">
                                    <i class="fas fa-edit me-1"></i>Edit Limit
                                </button>
                            }
                            @if (limit.CurrentUsage > 0)
                            {
                                <button class="btn btn-sm btn-outline-warning" @onclick="@(() => ResetUsage(limit.LimitCode))"
                                        disabled="@_isProcessing" title="Reset current usage to zero">
                                    <i class="fas fa-undo me-1"></i>Reset Usage
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
