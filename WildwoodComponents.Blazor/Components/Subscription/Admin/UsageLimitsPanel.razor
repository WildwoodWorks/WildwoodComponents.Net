@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Shared.Models
@inherits BaseWildwoodComponent

@if (IsLoading)
{
    <div class="ww-usage-loading text-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_limits.Count == 0)
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No usage limits are configured for this subscription.
    </div>
}
else
{
    <div class="ww-usage-limits-panel">
        @foreach (var limit in _limits)
        {
            <div class="ww-usage-limit-item mb-3 p-3 border rounded">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <strong>@limit.DisplayName</strong>
                        @if (!string.IsNullOrEmpty(limit.Unit))
                        {
                            <small class="text-muted ms-1">(@limit.Unit)</small>
                        }
                    </div>
                    <div>
                        @if (limit.IsUnlimited)
                        {
                            <span class="badge bg-success">
                                <i class="fas fa-infinity me-1"></i>Unlimited
                            </span>
                        }
                        else if (limit.IsHardBlocked)
                        {
                            <span class="badge bg-danger">
                                <i class="fas fa-ban me-1"></i>Blocked
                            </span>
                        }
                        else if (limit.IsExceeded)
                        {
                            <span class="badge bg-danger">
                                <i class="fas fa-exclamation-triangle me-1"></i>Exceeded
                            </span>
                        }
                        else if (limit.IsAtWarningThreshold)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="fas fa-exclamation-circle me-1"></i>Warning
                            </span>
                        }
                    </div>
                </div>

                <div class="progress mb-1" style="height: 8px;">
                    <div class="progress-bar @GetBarClass(limit)"
                         role="progressbar"
                         style="width: @(GetBarWidth(limit))%"
                         aria-valuenow="@limit.CurrentUsage"
                         aria-valuemin="0"
                         aria-valuemax="@limit.MaxValue">
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <small class="text-muted">
                        @if (limit.IsUnlimited)
                        {
                            <span>@limit.CurrentUsage.ToString("N0") used</span>
                        }
                        else
                        {
                            <span>@limit.CurrentUsage.ToString("N0") / @limit.MaxValue.ToString("N0")</span>
                        }
                    </small>
                    @if (!limit.IsUnlimited)
                    {
                        <small class="text-muted">@((int)Math.Round(limit.UsagePercent))%</small>
                    }
                </div>

                @if (!string.IsNullOrEmpty(limit.StatusMessage))
                {
                    <small class="text-muted d-block mt-1">
                        <i class="fas fa-info-circle me-1"></i>@limit.StatusMessage
                    </small>
                }
            </div>
        }
    </div>
}
