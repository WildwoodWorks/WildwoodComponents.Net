@using WildwoodComponents.Blazor.Models
@using WildwoodComponents.Blazor.Services
@using WildwoodComponents.Blazor.Components.Base
@using Microsoft.Extensions.Logging
@inherits BaseWildwoodComponent

<div class="@GetRootCssClasses() ai-chat-container @(IsSidebarOpen ? "sidebar-open" : "sidebar-closed")">
    <!-- Left Sidebar Navigation -->
    <div class="ai-chat-sidebar @(IsSidebarOpen ? "open" : "")">
        <div class="ai-chat-sidebar-header">
            <button @onclick="CreateNewSession" class="ai-chat-new-chat-btn" title="New Chat">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
                <span>New Chat</span>
            </button>
            <button @onclick="ToggleSidebar" class="ai-chat-sidebar-close-btn" title="Close sidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
                </svg>
            </button>
        </div>
        
        @if (Settings.EnableSessions)
        {
            <div class="ai-chat-sidebar-content">
                <div class="ai-chat-sessions-list">
                    @if (Sessions.Count > 0)
                    {
                        @foreach (var session in Sessions)
                        {
                            <div class="ai-chat-session-item @(session.Id == CurrentSessionId ? "active" : "")" 
                                 @onclick="() => LoadSessionFromMenu(session.Id)"
                                 @oncontextmenu="() => ShowSessionDetails(session)"
                                 @oncontextmenu:preventDefault="true"
                                 title="@FormatSessionTooltip(session)">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="ai-chat-session-icon">
                                    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
                                </svg>
                                <span class="ai-chat-session-name-text">@session.Name</span>
                                @if (session.Id == CurrentSessionId)
                                {
                                    <div class="ai-chat-session-actions">
                                        <button @onclick:stopPropagation="true" @onclick="RenameCurrentSession" class="ai-chat-session-action-btn" title="Rename">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                            </svg>
                                        </button>
                                        <button @onclick:stopPropagation="true" @onclick="() => ShowSessionDetails(session)" class="ai-chat-session-action-btn" title="Details">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                                            </svg>
                                        </button>
                                        <button @onclick:stopPropagation="true" @onclick="DeleteCurrentSession" class="ai-chat-session-action-btn delete" title="Delete">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                            </svg>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ai-chat-no-sessions">
                            <p>No previous chats</p>
                        </div>
                    }
                </div>
            </div>
        }
        
        @if (Configurations.Count > 1 && Settings.ShowConfigurationSelector)
        {
            <div class="ai-chat-sidebar-footer">
                <select @onchange="OnConfigurationChanged" class="ai-chat-config-select">
                    @foreach (var config in Configurations)
                    {
                        <option value="@config.Id" selected="@(config.Id == CurrentConfigurationId)">
                            @config.Name
                        </option>
                    }
                </select>
            </div>
        }
    </div>
    
    <!-- Sidebar Overlay (for mobile) -->
    @if (IsSidebarOpen)
    {
        <div class="ai-chat-sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    <!-- Main Chat Area -->
    <div class="ai-chat-main">
        <!-- Floating sidebar toggle button (when sidebar is closed) -->
        @if (!IsSidebarOpen)
        {
            <button @onclick="ToggleSidebar" class="ai-chat-sidebar-toggle-floating" title="Open sidebar">
                <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" class="bi bi-three-dots-vertical">
                    <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                </svg>
            </button>
        }

        <!-- Messages Container -->
        <div class="ai-chat-messages" @ref="messagesContainer">
            @if (Settings.ShowDebugInfo)
            {
                <div class="ai-chat-debug">
                    DEBUG: Total Messages = @Messages.Count (Visible: @GetVisibleMessagesCount())
                </div>
            }
            
            @if (GetVisibleMessagesCount() > 0)
            {
                @foreach (var message in GetVisibleMessages())
                {
                    <div class="ai-chat-message @GetMessageClass(message)">
                        @if (Settings.ShowDebugInfo)
                        {
                            <div class="ai-chat-message-header" style="display: flex !important;">
                                <span class="ai-chat-message-role" style="display: inline !important;">@GetDisplayRole(message.Role)</span>
                                <span class="ai-chat-message-time" style="display: inline !important;">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                        }
                        <div class="ai-chat-message-content">
                            @if (message.IsError)
                            {
                                <div class="ai-chat-error">@message.Content</div>
                            }
                            else
                            {
                                @((MarkupString)FormatMessageContent(message.Content))
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Empty State - Centered Welcome Message -->
                <div class="ai-chat-empty">
                    <p>@(Settings.WelcomeMessage ?? "What's on the agenda today?")</p>
                </div>
            }

            <!-- Typing Indicator -->
            @if (TypingIndicator.IsVisible)
            {
                <div class="ai-chat-message ai-chat-message-assistant">
                    <div class="ai-chat-message-content">
                        <div class="ai-chat-typing">
                            <div class="ai-chat-typing-dots">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Input Area -->
        <div class="ai-chat-input-area">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="ai-chat-error-banner">
                    @ErrorMessage
                    <button @onclick="ClearError" class="ai-chat-error-close">&times;</button>
                </div>
            }
            
            @* Microphone Permission Denied Banner *@
            @if (MicrophonePermissionDenied)
            {
                <div class="ai-chat-permission-banner">
                    <div class="ai-chat-permission-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/>
                            <path d="M19 19L5 5" stroke="currentColor" stroke-width="2" fill="none"/>
                        </svg>
                    </div>
                    <div class="ai-chat-permission-content">
                        <strong>Microphone Access Required</strong>
                        <p>@(MicrophonePermissionError ?? "Please enable microphone access to use voice input.")</p>
                        @if (!string.IsNullOrEmpty(MicrophonePermissionInstructions))
                        {
                            <details class="ai-chat-permission-instructions">
                                <summary>How to enable microphone access on @(MicrophonePermissionPlatform ?? "your device")</summary>
                                <pre>@MicrophonePermissionInstructions</pre>
                            </details>
                        }
                    </div>
                    <div class="ai-chat-permission-actions">
                        <button @onclick="RetryMicrophonePermission" class="ai-chat-permission-retry-btn">
                            Try Again
                        </button>
                        <button @onclick="DismissMicrophonePermissionError" class="ai-chat-permission-dismiss-btn">&times;</button>
                    </div>
                </div>
            }
            
            @if (IsListeningForSpeech)
            {
                <div class="ai-chat-speech-status">
                    <span class="ai-chat-listening-indicator"></span>
                    Listening... @InterimTranscript
                </div>
            }
            
            @if (Settings.ShowDebugInfo)
            {
                <div class="ai-chat-debug">
                    <strong>CanSendMessage:</strong> @CanSendMessage | 
                    <strong>IsLoading:</strong> @IsLoading | 
                    <strong>Message:</strong> "@CurrentMessage"
                </div>
            }
            
            <!-- TTS Settings Panel - Now positioned relative to input area -->
            @if (Settings.EnableTextToSpeech && Settings.UseServerTTS && ShowTTSSettings)
            {
                <div class="ai-chat-tts-settings-panel @(IsUsingBrowserTTS ? "fallback-mode" : "")">
                    <div class="ai-chat-tts-settings-header">
                        <span>Voice Settings</span>
                        <button @onclick="ToggleTTSSettings" class="ai-chat-tts-settings-close">&times;</button>
                    </div>
                    <div class="ai-chat-tts-settings-content">
                        @if (IsUsingBrowserTTS && !IsLoadingVoices)
                        {
                            <div class="ai-chat-tts-error-message">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="ai-chat-tts-error-icon">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                                </svg>
                                <div class="ai-chat-tts-error-text">
                                    <strong>Voice service unavailable</strong>
                                    <p>Could not connect to the TTS server. Please check your connection or try again.</p>
                                </div>
                            </div>
                            <div class="ai-chat-tts-setting-row">
                                <button @onclick="RetryLoadVoices" 
                                        class="ai-chat-tts-retry-btn"
                                        disabled="@IsLoadingVoices">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 6px;">
                                        <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                    </svg>
                                    <span>Retry Connection</span>
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="ai-chat-tts-setting-row">
                                <label for="voice-select">Voice</label>
                                @if (IsLoadingVoices)
                                {
                                    <div class="ai-chat-tts-loading">Loading voices...</div>
                                }
                                else if (AvailableVoices.Count == 0)
                                {
                                    <div class="ai-chat-tts-loading">No voices available</div>
                                }
                                else
                                {
                                    <select id="voice-select" 
                                            value="@SelectedVoice"
                                            @onchange="OnVoiceChanged" 
                                            class="ai-chat-tts-select">
                                        @foreach (var voice in AvailableVoices)
                                        {
                                            <option value="@voice.Id">
                                                @voice.Name - @voice.Description
                                            </option>
                                        }
                                    </select>
                                }
                            </div>
                            
                            <div class="ai-chat-tts-setting-row">
                                <label for="speed-range">Speed: @SelectedSpeed.ToString("0.0")x</label>
                                <div class="ai-chat-tts-speed-control">
                                    <span class="ai-chat-tts-speed-label">0.5x</span>
                                    <input type="range" 
                                           id="speed-range" 
                                           min="0.5" 
                                           max="2.0" 
                                           step="0.1" 
                                           value="@SelectedSpeed.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                           @oninput="OnSpeedChanged"
                                           class="ai-chat-tts-slider" />
                                    <span class="ai-chat-tts-speed-label">2x</span>
                                </div>
                            </div>
                            
                            <div class="ai-chat-tts-setting-row">
                                <button @onclick="TestVoice" 
                                        class="ai-chat-tts-test-btn"
                                        disabled="@(IsSpeakingMessage || AvailableVoices.Count == 0)">
                                    @if (IsSpeakingMessage)
                                    {
                                        <span>Speaking...</span>
                                    }
                                    else
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 6px;">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                        <span>Test Voice</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            
            <!-- Input Container - Pill Shape -->
            <div class="ai-chat-input-container">
                @if (Settings.EnableFileUpload)
                {
                    <button class="ai-chat-action-btn ai-chat-attach-btn" title="Attach" disabled="@IsLoading">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                    </button>
                }
                
                @* Speech Controls Popup Menu *@
                @if (Settings.EnableSpeechToText || Settings.EnableTextToSpeech)
                {
                    <button @onclick="ToggleSpeechMenu" 
                            class="ai-chat-speech-menu-toggle @(ShowSpeechMenu ? "active" : "") @(IsListeningForSpeech ? "listening" : "")" 
                            title="Voice options"
                            disabled="@IsLoading">
                        @if (IsListeningForSpeech)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/>
                            </svg>
                        }
                        else if (IsSpeakingMessage)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/>
                            </svg>
                        }
                        @if (HasActiveSpeechFeature && !IsListeningForSpeech && !IsSpeakingMessage)
                        {
                            <span class="ai-chat-menu-indicator"></span>
                        }
                    </button>
                    
                    @if (ShowSpeechMenu)
                    {
                        <div class="ai-chat-speech-menu">
                            <div class="ai-chat-speech-menu-header">
                                <span>Voice Options</span>
                                <button @onclick="CloseSpeechMenu" class="ai-chat-speech-menu-close">&times;</button>
                            </div>
                            
                            @if (Settings.EnableSpeechToText)
                            {
                                <button @onclick="@(() => { ToggleSpeechToText(); CloseSpeechMenu(); })" 
                                        class="ai-chat-speech-menu-item @(IsSpeechToTextEnabled ? "active" : "") @(IsListeningForSpeech ? "listening" : "")">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg>
                                    <span class="ai-chat-speech-menu-item-text">Voice Input</span>
                                    <span class="ai-chat-speech-menu-item-status">
                                        @if (IsListeningForSpeech) { <text>Listening</text> }
                                        else if (IsSpeechToTextEnabled) { <text>On</text> }
                                        else { <text>Off</text> }
                                    </span>
                                </button>
                            }
                            
                            @if (Settings.EnableTextToSpeech)
                            {
                                <button @onclick="@(() => { ToggleTextToSpeech(); CloseSpeechMenu(); })" 
                                        class="ai-chat-speech-menu-item @(IsTextToSpeechEnabled ? "active" : "") @(IsSpeakingMessage ? "speaking" : "")">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                                    <span class="ai-chat-speech-menu-item-text">AI Voice</span>
                                    <span class="ai-chat-speech-menu-item-status">
                                        @if (IsSpeakingMessage) { <text>Speaking</text> }
                                        else if (IsTextToSpeechEnabled) { <text>On</text> }
                                        else { <text>Off</text> }
                                    </span>
                                </button>
                                
                                @if (Settings.UseServerTTS && IsTextToSpeechEnabled)
                                {
                                    <div class="ai-chat-speech-menu-divider"></div>
                                    
                                    <button @onclick="@(() => { ToggleTTSSettings(); CloseSpeechMenu(); })" 
                                            class="ai-chat-speech-menu-item">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c.04.31.06.63.06.94s-.02.63-.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                                        <span class="ai-chat-speech-menu-item-text">Voice Settings</span>
                                    </button>
                                }
                            }
                        </div>
                    }
                }
                
                <textarea value="@CurrentMessage"
                         @oninput="OnInputChanged"
                         placeholder="@(Settings.PlaceholderText ?? "Ask anything")"
                         class="ai-chat-input"
                         rows="1"
                         disabled="@IsLoading"
                         maxlength="@Settings.MaxMessageLength"
                         @ref="messageInput"></textarea>
                
                <div class="ai-chat-input-actions">
                    @if (Settings.EnableSpeechToText && IsSpeechToTextEnabled)
                    {
                        <button @onclick="@(IsListeningForSpeech ? StopListening : StartListening)" 
                                class="ai-chat-action-btn ai-chat-mic-btn @(IsListeningForSpeech ? "listening" : "")" 
                                title="@(IsListeningForSpeech ? "Stop listening" : "Start voice input")"
                                disabled="@IsLoading">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg>
                        </button>
                    }

                    @if (IsSpeakingMessage)
                    {
                        <button @onclick="StopSpeaking"
                                class="ai-chat-action-btn ai-chat-stop-tts-btn"
                                title="Stop speaking">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <rect x="6" y="6" width="12" height="12" rx="2"/>
                            </svg>
                        </button>
                    }
                    
                    <button @onclick="SendMessage" 
                            class="ai-chat-send-btn @(CanSendMessage ? "enabled" : "")" 
                            disabled="@(!CanSendMessage)"
                            title="Send">
                        @if (IsLoading)
                        {
                            <div class="ai-chat-spinner"></div>
                        }
                        else
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <rect x="4" y="10" width="2" height="4" rx="1"/>
                                <rect x="8" y="7" width="2" height="10" rx="1"/>
                                <rect x="12" y="4" width="2" height="16" rx="1"/>
                                <rect x="16" y="7" width="2" height="10" rx="1"/>
                                <rect x="20" y="10" width="2" height="4" rx="1"/>
                            </svg>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* Session Details Popup - Touch-friendly alternative to tooltips *@
@if (ShowSessionDetailsPopup && SelectedSessionForDetails != null)
{
    <div class="ai-chat-session-details-overlay" @onclick="HideSessionDetails">
        <div class="ai-chat-session-details-popup" @onclick:stopPropagation="true">
            <div class="ai-chat-session-details-header">
                <h4>Session Details</h4>
                <button @onclick="HideSessionDetails" class="ai-chat-session-details-close">&times;</button>
            </div>
            <div class="ai-chat-session-details-content">
                <div class="ai-chat-session-details-name">
                    @SelectedSessionForDetails.Name
                </div>
                <div class="ai-chat-session-details-info">
                    <div class="ai-chat-session-details-row">
                        <span class="ai-chat-session-details-label">Created:</span>
                        <span class="ai-chat-session-details-value">@SelectedSessionForDetails.CreatedAt.ToLocalTime().ToString("f")</span>
                    </div>
                    @if (SelectedSessionForDetails.LastAccessedAt != SelectedSessionForDetails.CreatedAt)
                    {
                        <div class="ai-chat-session-details-row">
                            <span class="ai-chat-session-details-label">Last accessed:</span>
                            <span class="ai-chat-session-details-value">@SelectedSessionForDetails.LastAccessedAt.ToLocalTime().ToString("f")</span>
                        </div>
                    }
                    <div class="ai-chat-session-details-row">
                        <span class="ai-chat-session-details-label">Messages:</span>
                        <span class="ai-chat-session-details-value">@SelectedSessionForDetails.MessageCount</span>
                    </div>
                    <div class="ai-chat-session-details-row">
                        <span class="ai-chat-session-details-label">Status:</span>
                        <span class="ai-chat-session-details-value @(SelectedSessionForDetails.IsActive ? "active" : "ended")">
                            @(SelectedSessionForDetails.IsActive ? "Active" : "Ended")
                        </span>
                    </div>
                </div>
            </div>
            <div class="ai-chat-session-details-actions">
                <button @onclick="LoadSessionFromDetails" class="ai-chat-session-details-btn primary">
                    Open Session
                </button>
                <button @onclick="HideSessionDetails" class="ai-chat-session-details-btn">
                    Close
                </button>
            </div>
        </div>
    </div>
}
