    private void ToggleMode()
    {
        // Check if we're trying to switch to registration mode but it's not allowed
        var registrationAllowed = _authConfig?.AllowTokenRegistration == true || _authConfig?.AllowOpenRegistration == true;
        if (_isLogin && _authConfig != null && !registrationAllowed)
        {
            _ = HandleErrorAsync(new InvalidOperationException("Registration is not allowed for this application."), 
                "Switching to registration mode");
            return;
        }

        _isLogin = !_isLogin;
        ClearError();
        _successMessage = "";
        
        // Initialize login model with AppId
        _model = new LoginRequest { AppId = AppId };
        
        StateHasChanged();
    }

    private void ApplyAuthenticationSettings()
    {
        if (_authConfig == null) return;

        // Override ShowPasswordField based on configuration
        if (!_authConfig.AllowLocalAuth)
        {
            ShowPasswordField = false;
        }
    }

    private bool IsProviderAllowed(AuthProvider provider)
    {
        if (_authConfig == null) return true;

        // If local auth is disabled and this is email/password
        if (!_authConfig.AllowLocalAuth && 
            provider.Name.Equals("Email", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        // Check if provider is in the available list (already filtered for enabled)
        return _availableProviders?.Any(p => p.Name.Equals(provider.Name, StringComparison.OrdinalIgnoreCase)) == true;
    }

