    [Inject] private IDisclaimerService? DisclaimerServiceInstance { get; set; }

    private async Task HandlePasswordReset()
    {
        _successMessage = "";
        ClearError();

        // Validate passwords match
        if (_resetModel.NewPassword != _resetModel.ConfirmPassword)
        {
            await HandleErrorAsync(new InvalidOperationException("Passwords do not match."), "Validation");
            return;
        }

        // Validate password is not empty
        if (string.IsNullOrWhiteSpace(_resetModel.NewPassword))
        {
            await HandleErrorAsync(new InvalidOperationException("New password is required."), "Validation");
            return;
        }

        await ExecuteAsync(async () =>
        {
            // Call the password reset API
            await AuthService.ResetPasswordAsync(_resetModel.NewPassword, _resetModel.ConfirmPassword, AppId ?? "");

            // Password reset successful - now complete the authentication
            _showPasswordReset = false;
            _successMessage = "Password reset successful!";

            if (_pendingAuthResponse != null)
            {
                // Update the response to indicate password reset is no longer required
                _pendingAuthResponse.RequiresPasswordReset = false;
                await OnAuthenticationSuccess.InvokeAsync(_pendingAuthResponse);
            }

            _pendingAuthResponse = null;
            _resetModel = new PasswordResetModel();
        }, "Resetting password");
    }

