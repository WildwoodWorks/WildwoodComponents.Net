    }

    protected override async Task OnComponentErrorAsync(Exception exception, string context)
    {
        // Send the detailed error message to the parent component
        if (OnAuthenticationError.HasDelegate)
        {
            await OnAuthenticationError.InvokeAsync(exception.Message);
        }

        // Reset captcha if it failed
        if (ShouldShowCaptcha())
        {
            await ResetCaptcha();
        }
    }

    private async Task HandleSocialAuth(AuthProvider provider)
    {
        await ExecuteAsync(async () =>
        {
            var response = await AuthService.AuthenticateWithProviderAsync(provider.Name, AppId ?? "");

            // Check if disclaimer acceptance is required
            if (response.RequiresDisclaimerAcceptance && response.PendingDisclaimers?.Any() == true)
            {
                _pendingAuthResponse = response;
                _pendingDisclaimers = response.PendingDisclaimers;
                _showDisclaimers = true;
                StateHasChanged();
                return;
            }

            await OnAuthenticationSuccess.InvokeAsync(response);
        }, $"Social authentication with {provider.Name}");
    }

