    /// <summary>
    /// Determines whether to show detailed error messages.
    /// Uses the configuration value if available, otherwise falls back to the parameter.
    /// </summary>
    private bool ShouldShowDetailedErrors()
    {
        // If configuration is loaded, use its value
        if (_authConfig != null)
        {
            return _authConfig.ShowDetailedErrors;
        }
        
        // Fall back to the parameter value
        return ShowDetailedErrors;
    }

    private async Task<string> GetPlatformAsync()
    {
        // Detect platform based on user agent or environment
        try
        {
            var userAgent = await JS.InvokeAsync<string>("eval", "navigator.userAgent");
            
            if (userAgent.Contains("Mobile") || userAgent.Contains("Android"))
                return "Mobile";
            else if (userAgent.Contains("iPad") || userAgent.Contains("iPhone"))
                return "iOS";
            else if (userAgent.Contains("Macintosh"))
                return "macOS";
            else if (userAgent.Contains("Windows"))
                return "Windows";
            else
                return "Web";
        }
        catch
        {
            return "Web"; // Fallback
        }
    }

    private async Task<string> GetDeviceInfoAsync()
    {
        // Get basic device information
        try
        {
            var userAgent = await JS.InvokeAsync<string>("eval", "navigator.userAgent");
            var platform = await JS.InvokeAsync<string>("eval", "navigator.platform");
            
            var deviceInfo = $"{platform} - {userAgent}";
            return deviceInfo.Substring(0, Math.Min(200, deviceInfo.Length));
        }
        catch
        {
            return "Unknown Device"; // Fallback
        }
    }
