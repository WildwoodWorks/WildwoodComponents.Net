    /// <summary>
    /// Handles passkey authentication using WebAuthn
    /// </summary>
    private async Task HandlePasskeyLogin()
    {
        _successMessage = "";
        ClearError();

        await ExecuteAsync(async () =>
        {
            if (string.IsNullOrEmpty(AppId))
            {
                throw new InvalidOperationException("AppId is required for passkey authentication.");
            }

            // Get authentication options from server
            var options = await AuthService.GetPasskeyAuthenticationOptionsAsync(AppId);

            // Call WebAuthn browser API via JS interop
            var credential = await JS.InvokeAsync<System.Text.Json.JsonElement>("webauthnAuthenticate", options);

            // Send assertion to server for verification
            var response = await AuthService.VerifyPasskeyAuthenticationAsync(AppId, credential);

            await OnAuthenticationSuccess.InvokeAsync(response);
            _successMessage = "Passkey authentication successful!";
        }, "Authenticating with passkey");
    }

    /// <summary>
    /// Handles passkey registration after successful login
    /// </summary>
    private async Task RegisterPasskey()
    {
        _successMessage = "";
        ClearError();

        await ExecuteAsync(async () =>
        {
            if (string.IsNullOrEmpty(AppId))
            {
                throw new InvalidOperationException("AppId is required for passkey registration.");
            }

            // Get registration options from server
            var options = await AuthService.GetPasskeyRegistrationOptionsAsync(AppId);

            // Call WebAuthn browser API via JS interop
            var credential = await JS.InvokeAsync<System.Text.Json.JsonElement>("webauthnRegister", options);

            // Send credential to server to complete registration
            await AuthService.CompletePasskeyRegistrationAsync(AppId, credential);

            _showPasskeyRegistration = false;
            _successMessage = "Passkey registered successfully! You can now sign in using your biometrics.";
        }, "Registering passkey");
    }

