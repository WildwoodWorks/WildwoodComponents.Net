    private async Task SelectTwoFactorMethod(TwoFactorMethodInfo method)
    {
        _selectedTwoFactorMethod = method;
        _twoFactorCode = "";
        ClearError();

        // If email 2FA is selected, send the code
        if (method.ProviderType == "TwoFactorEmail" && !string.IsNullOrEmpty(_twoFactorSessionId))
        {
            await ExecuteAsync(async () =>
            {
                var result = await AuthService.SendTwoFactorCodeAsync(_twoFactorSessionId);
                if (result.Success)
                {
                    _twoFactorMaskedDestination = result.MaskedDestination;
                    _successMessage = $"Verification code sent to {result.MaskedDestination}";
                }
                else
                {
                    throw new InvalidOperationException(result.ErrorMessage ?? "Failed to send verification code");
                }
            }, "Sending verification code");
        }

        StateHasChanged();
    }

    private async Task HandleTwoFactorSubmit()
    {
        ClearError();
        _successMessage = "";

        if (string.IsNullOrWhiteSpace(_twoFactorCode))
        {
            await HandleErrorAsync(new InvalidOperationException("Please enter the verification code."), "Validation");
            return;
        }

        if (_twoFactorCode.Length != 6)
        {
            await HandleErrorAsync(new InvalidOperationException("Verification code must be 6 digits."), "Validation");
            return;
        }

        await ExecuteAsync(async () =>
        {
            var request = new TwoFactorVerifyRequest
            {
                SessionId = _twoFactorSessionId ?? "",
                Code = _twoFactorCode,
                ProviderType = _selectedTwoFactorMethod?.ProviderType ?? "",
                RememberDevice = _rememberDevice,
                DeviceFingerprint = await GetDeviceInfoAsync(),
                DeviceName = await GetPlatformAsync()
            };

            var result = await AuthService.VerifyTwoFactorCodeAsync(request);

            if (result.Success && result.AuthResponse != null)
            {
                // Store trusted device token if provided
                if (!string.IsNullOrEmpty(result.TrustedDeviceToken))
                {
                    // Store in local storage for future logins
                    await JS.InvokeVoidAsync("localStorage.setItem", "trustedDeviceToken", result.TrustedDeviceToken);
                }

                // Check if password reset is still required
                if (result.AuthResponse.RequiresPasswordReset)
                {
                    _pendingAuthResponse = result.AuthResponse;
                    _showTwoFactor = false;
                    _showPasswordReset = true;
                    _resetModel = new PasswordResetModel();

                    if (!string.IsNullOrEmpty(AppId))
                    {
                        _passwordRequirements = await AuthService.GetPasswordRequirementsAsync(AppId);
                    }

                    StateHasChanged();
                    return;
                }

                // Check if disclaimer acceptance is required
                if (result.AuthResponse.RequiresDisclaimerAcceptance && result.AuthResponse.PendingDisclaimers?.Any() == true)
                {
                    _pendingAuthResponse = result.AuthResponse;
                    _pendingDisclaimers = result.AuthResponse.PendingDisclaimers;
                    _showTwoFactor = false;
                    _showDisclaimers = true;
                    StateHasChanged();
                    return;
                }

                _showTwoFactor = false;
                await OnAuthenticationSuccess.InvokeAsync(result.AuthResponse);
                _successMessage = "Login successful!";
            }
            else
            {
                throw new InvalidOperationException(result.ErrorMessage ?? "Verification failed. Please try again.");
            }
        }, "Verifying code");
    }

    private async Task HandleRecoveryCodeSubmit()
    {
        ClearError();
        _successMessage = "";

        if (string.IsNullOrWhiteSpace(_recoveryCode))
        {
            await HandleErrorAsync(new InvalidOperationException("Please enter a recovery code."), "Validation");
            return;
        }

        await ExecuteAsync(async () =>
        {
            var result = await AuthService.VerifyTwoFactorRecoveryCodeAsync(
                _twoFactorSessionId ?? "",
                _recoveryCode.Replace("-", "").Trim(),
                "web");

            if (result.Success && result.AuthResponse != null)
            {
                // Check if password reset is still required
                if (result.AuthResponse.RequiresPasswordReset)
                {
                    _pendingAuthResponse = result.AuthResponse;
                    _showTwoFactor = false;
                    _showPasswordReset = true;
                    _resetModel = new PasswordResetModel();

                    if (!string.IsNullOrEmpty(AppId))
                    {
                        _passwordRequirements = await AuthService.GetPasswordRequirementsAsync(AppId);
                    }

                    StateHasChanged();
                    return;
                }

                // Check if disclaimer acceptance is required
                if (result.AuthResponse.RequiresDisclaimerAcceptance && result.AuthResponse.PendingDisclaimers?.Any() == true)
                {
                    _pendingAuthResponse = result.AuthResponse;
                    _pendingDisclaimers = result.AuthResponse.PendingDisclaimers;
                    _showTwoFactor = false;
                    _showRecoveryCodeInput = false;
                    _showDisclaimers = true;
                    StateHasChanged();
                    return;
                }

                _showTwoFactor = false;
                _showRecoveryCodeInput = false;
                await OnAuthenticationSuccess.InvokeAsync(result.AuthResponse);
                _successMessage = "Login successful! Note: One of your recovery codes has been used.";
            }
            else
            {
                throw new InvalidOperationException(result.ErrorMessage ?? "Invalid recovery code. Please try again.");
            }
        }, "Verifying recovery code");
    }

    private async Task ResendTwoFactorCode()
    {
        if (string.IsNullOrEmpty(_twoFactorSessionId))
            return;

        ClearError();
        _successMessage = "";

        await ExecuteAsync(async () =>
        {
            var result = await AuthService.SendTwoFactorCodeAsync(_twoFactorSessionId);
            if (result.Success)
            {
                _twoFactorMaskedDestination = result.MaskedDestination;
                _successMessage = $"New verification code sent to {result.MaskedDestination}";
            }
            else
            {
                throw new InvalidOperationException(result.ErrorMessage ?? "Failed to resend verification code");
            }
        }, "Resending verification code");
    }

    private void CancelTwoFactor()
    {
        _showTwoFactor = false;
        _showRecoveryCodeInput = false;
        _twoFactorCode = "";
        _recoveryCode = "";
        _twoFactorSessionId = null;
        _selectedTwoFactorMethod = null;
        _availableTwoFactorMethods = null;
        _pendingAuthResponse = null;
        ClearError();
        _successMessage = "";
        StateHasChanged();
    }

