@using WildwoodComponents.Razor.Models
@using WildwoodComponents.Razor.Components.Feedback
@model FeedbackWidgetViewModel

@{
    var cid = Model.ComponentId;
    var cfg = Model.Config;
    var isBottomLeft = string.Equals(cfg.WidgetPosition, "bottom-left", StringComparison.OrdinalIgnoreCase);
    var accent = string.IsNullOrEmpty(cfg.WidgetColor) ? "#4A90D9" : cfg.WidgetColor;
}

@if (cfg.IsEnabled)
{
    <div id="ww-feedback-@cid"
         class="ww-feedback"
         style="--ww-feedback-color: @accent;"
         data-component-id="@cid"
         data-app-id="@Model.AppId"
         data-proxy-url="@Model.ProxyBaseUrl"
         data-authenticated="@Model.IsAuthenticated.ToString().ToLower()"
         data-position="@(isBottomLeft ? "bottom-left" : "bottom-right")"
         data-require-screenshot="@cfg.RequireScreenshot.ToString().ToLower()"
         data-screenshot-quality="@cfg.ScreenshotQuality"
         data-screenshot-max-kb="@cfg.ScreenshotMaxSizeKb"
         data-enable-duplicate-detection="@cfg.EnableDuplicateDetection.ToString().ToLower()"
         data-allow-attachments="@cfg.AllowAttachments.ToString().ToLower()"
         data-max-attachment-kb="@cfg.MaxAttachmentSizeKb"
         data-allowed-attachment-types="@(cfg.AllowedAttachmentTypes ?? "")">

        @* ===== Floating button ===== *@
        <button type="button"
                class="ww-feedback-btn @(isBottomLeft ? "ww-bottom-left" : "")"
                title="Send Feedback"
                aria-label="Open feedback form">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
            </svg>
        </button>

        @* ===== Slide-out panel (hidden until opened) ===== *@
        <div class="ww-feedback-panel @(isBottomLeft ? "ww-bottom-left" : "")"
             role="dialog"
             aria-label="Feedback form"
             style="display:none;">
            <div class="ww-feedback-panel-header">
                <span>Send Feedback</span>
                <button type="button" class="ww-feedback-close" title="Close" aria-label="Close feedback form">&times;</button>
            </div>

            <div class="ww-feedback-panel-body">
                <label for="ww-fb-type-@cid">Type</label>
                <select id="ww-fb-type-@cid" class="ww-feedback-type">
                    @foreach (var type in Model.FeedbackTypes)
                    {
                        <option value="@type">@FeedbackWidgetViewComponent.FormatTypeLabel(type)</option>
                    }
                </select>

                <label for="ww-fb-title-@cid">Title <span class="ww-feedback-req">*</span></label>
                <input type="text"
                       id="ww-fb-title-@cid"
                       class="ww-feedback-title"
                       placeholder="Brief summary"
                       maxlength="200" />

                <div class="ww-feedback-duplicate-warning" style="display:none;"></div>

                <label for="ww-fb-desc-@cid">Description <span class="ww-feedback-req">*</span></label>
                <textarea id="ww-fb-desc-@cid"
                          class="ww-feedback-desc"
                          placeholder="Tell us more..."
                          rows="3"></textarea>

                @if (!Model.IsAuthenticated)
                {
                    <label for="ww-fb-email-@cid">Email</label>
                    <input type="email" id="ww-fb-email-@cid" class="ww-feedback-email" placeholder="your@@email.com" />

                    <label for="ww-fb-name-@cid">Name (optional)</label>
                    <input type="text" id="ww-fb-name-@cid" class="ww-feedback-name" placeholder="Your name" />
                }

                <div class="ww-feedback-screenshot-section">
                    <label>
                        Screenshot
                        @if (cfg.RequireScreenshot)
                        {
                            <span class="ww-feedback-req">*</span>
                        }
                    </label>
                    <div class="ww-feedback-screenshot-btns">
                        <button type="button" class="ww-feedback-capture-area">&#128247; Capture Area</button>
                        <button type="button" class="ww-feedback-capture-full">&#128248; Full Page</button>
                    </div>
                    <div class="ww-feedback-screenshot-preview" style="display:none;"></div>
                </div>

                @if (cfg.AllowAttachments)
                {
                    <div class="ww-feedback-attachment-section">
                        <label>Attachments</label>
                        <div class="ww-feedback-attachment-drop">
                            <input type="file" class="ww-feedback-attachment-input" multiple
                                   style="display:none;" accept="@(cfg.AllowedAttachmentTypes ?? "")" />
                            <span class="ww-feedback-attachment-label">
                                Drop files here or <a href="#" class="ww-feedback-attachment-browse">browse</a>
                            </span>
                        </div>
                        <div class="ww-feedback-attachment-list"></div>
                    </div>
                }

                <div class="ww-feedback-form-error" style="display:none;"></div>

                <button type="button" class="ww-feedback-submit-btn">Submit Feedback</button>
            </div>
        </div>
    </div>
}

<style>
    .ww-feedback {
        font-family: var(--ww-font-family, inherit);
    }

    /* ---------- Floating button ---------- */
    .ww-feedback .ww-feedback-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--ww-feedback-color, var(--ww-primary, #4A90D9));
        color: #fff;
        border: none;
        cursor: pointer;
        box-shadow: var(--ww-shadow-lg, 0 4px 12px rgba(0, 0, 0, 0.25));
        z-index: 9998;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s, box-shadow 0.2s;
        user-select: none;
        touch-action: none;
    }

    .ww-feedback .ww-feedback-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
    }

    .ww-feedback .ww-feedback-btn:focus-visible {
        outline: 2px solid var(--ww-feedback-color, var(--ww-primary, #4A90D9));
        outline-offset: 3px;
    }

    .ww-feedback .ww-feedback-btn.ww-bottom-left {
        right: auto;
        left: 24px;
    }

    /* ---------- Panel ---------- */
    .ww-feedback .ww-feedback-panel {
        position: fixed;
        bottom: 86px;
        right: 24px;
        width: 370px;
        max-height: 520px;
        background: var(--ww-bg-primary, #fff);
        color: var(--ww-text-primary, #212529);
        border-radius: var(--ww-border-radius, 12px);
        box-shadow: var(--ww-shadow-lg, 0 8px 32px rgba(0, 0, 0, 0.2));
        z-index: 9999;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--ww-border-color, #dee2e6);
        animation: ww-feedback-slide-up 0.25s ease-out;
    }

    .ww-feedback .ww-feedback-panel.ww-bottom-left {
        right: auto;
        left: 24px;
    }

    @@keyframes ww-feedback-slide-up {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .ww-feedback .ww-feedback-panel-header {
        padding: 14px 16px;
        background: var(--ww-feedback-color, var(--ww-primary, #4A90D9));
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        font-size: 15px;
    }

    .ww-feedback .ww-feedback-close {
        background: none;
        border: none;
        color: #fff;
        font-size: 18px;
        cursor: pointer;
        padding: 0 4px;
        opacity: 0.8;
    }

    .ww-feedback .ww-feedback-close:hover {
        opacity: 1;
    }

    .ww-feedback .ww-feedback-panel-body {
        padding: 16px;
        overflow-y: auto;
        flex: 1;
    }

    .ww-feedback .ww-feedback-panel-body label {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 4px;
        display: block;
        color: var(--ww-text-primary, #212529);
    }

    .ww-feedback .ww-feedback-req {
        color: var(--ww-danger, #dc3545);
    }

    .ww-feedback .ww-feedback-panel-body input,
    .ww-feedback .ww-feedback-panel-body select,
    .ww-feedback .ww-feedback-panel-body textarea {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid var(--ww-border-color, #ced4da);
        border-radius: var(--ww-border-radius-sm, 6px);
        font-size: 14px;
        margin-bottom: 10px;
        background: var(--ww-input-bg, #fff);
        color: var(--ww-text-primary, #212529);
        box-sizing: border-box;
    }

    .ww-feedback .ww-feedback-panel-body textarea {
        resize: vertical;
        min-height: 70px;
    }

    .ww-feedback .ww-feedback-panel-body input:focus,
    .ww-feedback .ww-feedback-panel-body select:focus,
    .ww-feedback .ww-feedback-panel-body textarea:focus {
        outline: none;
        border-color: var(--ww-focus-border, var(--ww-feedback-color, #4A90D9));
        box-shadow: 0 0 0 2px var(--ww-focus-ring, rgba(74, 144, 217, 0.2));
    }

    .ww-feedback .ww-feedback-panel-body input.ww-feedback-invalid,
    .ww-feedback .ww-feedback-panel-body textarea.ww-feedback-invalid {
        border-color: var(--ww-danger, #dc3545);
    }

    /* ---------- Screenshot section ---------- */
    .ww-feedback .ww-feedback-screenshot-section {
        margin-bottom: 10px;
    }

    .ww-feedback .ww-feedback-screenshot-btns {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
    }

    .ww-feedback .ww-feedback-screenshot-btns button {
        flex: 1;
        padding: 6px 8px;
        font-size: 12px;
        border: 1px solid var(--ww-border-color, #ced4da);
        border-radius: var(--ww-border-radius-sm, 6px);
        background: var(--ww-bg-tertiary, #f8f9fa);
        color: var(--ww-text-primary, #212529);
        cursor: pointer;
        transition: background 0.15s;
    }

    .ww-feedback .ww-feedback-screenshot-btns button:hover:not(:disabled) {
        background: var(--ww-bg-secondary, #e9ecef);
    }

    .ww-feedback .ww-feedback-screenshot-btns button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .ww-feedback .ww-feedback-screenshot-preview {
        position: relative;
        display: inline-block;
        max-width: 100%;
    }

    .ww-feedback .ww-feedback-screenshot-preview img {
        max-width: 100%;
        max-height: 100px;
        border-radius: var(--ww-border-radius-sm, 6px);
        border: 1px solid var(--ww-border-color, #dee2e6);
    }

    .ww-feedback .ww-feedback-remove-screenshot {
        position: absolute;
        top: -6px;
        right: -6px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--ww-danger, #dc3545);
        color: #fff;
        border: none;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    /* ---------- Duplicate warning + vote ---------- */
    .ww-feedback .ww-feedback-duplicate-warning {
        background: var(--ww-warning-bg, #fff3cd);
        color: var(--ww-warning-color, #856404);
        border: 1px solid var(--ww-warning, #ffc107);
        border-radius: var(--ww-border-radius-sm, 6px);
        padding: 8px 10px;
        font-size: 12px;
        margin-bottom: 10px;
    }

    .ww-feedback .ww-feedback-vote-btn {
        display: inline-block;
        margin-top: 6px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid var(--ww-warning-color, #856404);
        border-radius: var(--ww-border-radius-sm, 4px);
        background: rgba(255, 193, 7, 0.15);
        color: var(--ww-warning-color, #856404);
        cursor: pointer;
        transition: background 0.15s;
        width: auto !important;
    }

    .ww-feedback .ww-feedback-vote-btn:hover:not(:disabled) {
        background: rgba(255, 193, 7, 0.3);
    }

    .ww-feedback .ww-feedback-vote-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* ---------- Attachments ---------- */
    .ww-feedback .ww-feedback-attachment-section {
        margin-bottom: 10px;
    }

    .ww-feedback .ww-feedback-attachment-drop {
        border: 2px dashed var(--ww-border-color, #ced4da);
        border-radius: var(--ww-border-radius-sm, 6px);
        padding: 12px;
        text-align: center;
        font-size: 12px;
        color: var(--ww-text-muted, #6c757d);
        margin-bottom: 8px;
        cursor: pointer;
    }

    .ww-feedback .ww-feedback-attachment-drop.ww-dragover {
        border-color: var(--ww-feedback-color, var(--ww-primary, #4A90D9));
        background: var(--ww-bg-tertiary, #f8f9fa);
    }

    .ww-feedback .ww-feedback-attachment-list {
        max-height: 80px;
        overflow-y: auto;
    }

    .ww-feedback .ww-feedback-attachment-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 4px 8px;
        font-size: 12px;
        background: var(--ww-bg-tertiary, #f8f9fa);
        border-radius: 4px;
        margin-bottom: 4px;
    }

    .ww-feedback .ww-feedback-att-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
    }

    .ww-feedback .ww-feedback-att-remove {
        background: none;
        border: none;
        color: var(--ww-danger, #dc3545);
        font-size: 14px;
        cursor: pointer;
        padding: 0 4px;
        line-height: 1;
    }

    /* ---------- Form error + submit ---------- */
    .ww-feedback .ww-feedback-form-error {
        color: var(--ww-danger-color, #842029);
        background: var(--ww-danger-bg, #f8d7da);
        padding: 0.5rem 0.75rem;
        border-radius: var(--ww-border-radius-sm, 0.25rem);
        margin-bottom: 10px;
        font-size: 0.8rem;
    }

    .ww-feedback .ww-feedback-submit-btn {
        width: 100%;
        padding: 10px;
        background: var(--ww-feedback-color, var(--ww-primary, #4A90D9));
        color: var(--ww-btn-primary-text, #fff);
        border: none;
        border-radius: var(--ww-border-radius-sm, 6px);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
    }

    .ww-feedback .ww-feedback-submit-btn:hover:not(:disabled) {
        opacity: 0.9;
    }

    .ww-feedback .ww-feedback-submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* ---------- Responsive ---------- */
    @@media (max-width: 480px) {
        .ww-feedback .ww-feedback-panel {
            width: calc(100vw - 24px);
            right: 12px;
            left: 12px;
            bottom: 80px;
        }

        .ww-feedback .ww-feedback-panel.ww-bottom-left {
            right: 12px;
        }
    }
</style>

@* Self-included widget assets (mirrors the Authentication and AIProxy ViewComponents).
   feedback-widget.css carries the global rules for elements the JS creates at <body>
   (toast, screenshot-capture overlay, annotation editor) that the scoped <style> above
   cannot reach; feedback-widget.js wires up all interactivity and auto-initializes every
   .ww-feedback instance on the page. The script POSTs/GETs against the server-side proxy
   (data-proxy-url) — see README.md for the copy-paste proxy controller. *@
<link rel="stylesheet" href="~/_content/WildwoodComponents.Razor/css/feedback-widget.css" />
<script src="~/_content/WildwoodComponents.Razor/js/feedback-widget.js"></script>
