@model WildwoodComponents.Razor.Models.AIProxyViewModel

<div class="ww-ai-proxy" id="ww-ai-proxy"
     data-proxy-url="@Model.ProxyBaseUrl"
     data-configuration-id="@Model.ConfigurationId"
     data-configuration-name="@Model.ConfigurationName"
     data-allow-file-upload="@Model.AllowFileUpload.ToString().ToLower()"
     data-on-complete="@Model.OnCompleteCallback">

    @* Message area *@
    <div id="ww-ai-message" class="ww-alert" style="display:none;"></div>

    @* ===== PROMPT INPUT ===== *@
    <div class="ww-ai-input-area">
        <div class="mb-3">
            <label for="ww-ai-prompt" class="form-label fw-semibold">@Model.Title</label>
            <textarea class="form-control" id="ww-ai-prompt" rows="4"
                      placeholder="@Model.Placeholder"></textarea>
        </div>

        @if (Model.AllowFileUpload)
        {
            <div class="ww-ai-upload-zone mb-3" id="ww-ai-upload-zone">
                <div class="ww-ai-upload-content">
                    <i class="bi bi-cloud-arrow-up ww-ai-upload-icon"></i>
                    <p class="mb-1">Drag and drop a file here, or click to browse</p>
                    <p class="text-muted small mb-0">PDF, images, or documents</p>
                </div>
                <input type="file" id="ww-ai-file-input" class="d-none"
                       accept=".pdf,.png,.jpg,.jpeg,.gif,.bmp,.tiff,.doc,.docx" />
            </div>
            <div id="ww-ai-file-info" class="mb-3" style="display:none;">
                <span class="badge bg-secondary">
                    <i class="bi bi-paperclip"></i>
                    <span id="ww-ai-file-name"></span>
                    <button type="button" class="btn-close btn-close-white ms-2" id="ww-ai-file-remove"
                            aria-label="Remove file" style="font-size: 0.6rem;"></button>
                </span>
            </div>
        }

        <div class="d-grid">
            <button type="button" class="btn btn-primary" id="ww-ai-submit">
                <span class="ww-btn-text">@Model.SubmitLabel</span>
                <span class="ww-btn-spinner" style="display:none;">
                    <span class="ww-spinner"></span> Processing...
                </span>
            </button>
        </div>
    </div>

    @* ===== RESPONSE DISPLAY ===== *@
    <div id="ww-ai-response-area" class="ww-ai-response-area" style="display:none;">
        <hr />
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label class="form-label fw-semibold mb-0">Response</label>
            <div>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="ww-ai-copy"
                        title="Copy response">
                    <i class="bi bi-clipboard"></i> Copy
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="ww-ai-clear"
                        title="Clear and start over">
                    <i class="bi bi-arrow-counterclockwise"></i> Clear
                </button>
            </div>
        </div>
        <div id="ww-ai-response-content" class="ww-ai-response-content"></div>
        <div id="ww-ai-usage" class="text-muted small mt-2" style="display:none;"></div>
    </div>
</div>

<link rel="stylesheet" href="~/_content/WildwoodComponents.Razor/css/aiproxy.css" />
<script src="~/_content/WildwoodComponents.Razor/js/aiproxy.js"></script>
