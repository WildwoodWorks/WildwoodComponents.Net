@using WildwoodComponents.Shared.Models
@model WildwoodComponents.Razor.Models.TierPlansPanelViewModel

@{
    var cid = Model.ComponentId;
    string FormatPrice(decimal price, string currency) => price.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo(currency == "EUR" ? "de-DE" : "en-US"));
    bool IsEnterpriseTier(AppTierModel tier) => tier.PricingOptions.Count == 0 && !tier.IsFreeTier;
}

<div class="ww-tier-plans-panel" id="ww-tier-plans-@cid" data-component-id="@cid">
    @* Billing cycle toggle *@
    @if (Model.ShowBillingToggle && Model.HasMonthlyAndAnnual)
    {
        <div class="text-center mb-4">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-primary ww-admin-billing-btn" data-cycle="monthly">Monthly</button>
                <button type="button" class="btn btn-outline-primary ww-admin-billing-btn" data-cycle="annually">Annually</button>
            </div>
        </div>
    }

    @if (Model.Tiers.Count == 0)
    {
        <div class="text-center text-muted p-4">
            <i class="bi bi-info-circle me-1"></i> No plans available.
        </div>
    }
    else
    {
        <div class="row g-3 justify-content-center">
            @foreach (var tier in Model.Tiers)
            {
                var isCurrentPlan = Model.Subscription != null && Model.Subscription.AppTierId == tier.Id;
                var isEnterprise = IsEnterpriseTier(tier);

                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 ww-admin-plan-card @(isCurrentPlan ? "border-primary" : "")"
                         data-tier-id="@tier.Id" data-tier-name="@tier.Name" data-is-free="@tier.IsFreeTier.ToString().ToLower()">
                        @if (isCurrentPlan)
                        {
                            <div class="card-header bg-primary text-white text-center py-1 small">
                                <i class="bi bi-check-circle me-1"></i> Current Plan
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title text-center">
                                @if (!string.IsNullOrEmpty(tier.IconClass))
                                {
                                    <i class="@tier.IconClass me-1"></i>
                                }
                                @tier.Name
                                @if (!string.IsNullOrEmpty(tier.CustomBadgeText))
                                {
                                    <span class="badge bg-@(tier.BadgeColor ?? "primary") ms-1">@tier.CustomBadgeText</span>
                                }
                            </h6>

                            @if (!string.IsNullOrEmpty(tier.Description))
                            {
                                <p class="text-muted small text-center">@tier.Description</p>
                            }

                            @* Pricing *@
                            <div class="text-center mb-3">
                                @if (tier.IsFreeTier)
                                {
                                    <div class="fs-4 fw-bold text-success">Free</div>
                                }
                                else if (isEnterprise)
                                {
                                    <div class="fs-5 fw-bold">Custom</div>
                                }
                                else
                                {
                                    @foreach (var pricing in tier.PricingOptions)
                                    {
                                        var isDefault = pricing.IsDefault;
                                        var isMonthly = string.Equals(pricing.BillingFrequency, "Monthly", StringComparison.OrdinalIgnoreCase);
                                        var showInitially = isDefault || (isMonthly && !tier.PricingOptions.Any(p => p.IsDefault));
                                        <span class="ww-admin-price-option @(showInitially ? "" : "d-none")"
                                              data-pricing-id="@pricing.Id"
                                              data-price="@pricing.Price"
                                              data-billing="@pricing.BillingFrequency.ToLower()"
                                              data-is-default="@isDefault.ToString().ToLower()">
                                            <span class="fs-4 fw-bold">@FormatPrice(pricing.Price, Model.Currency)</span>
                                            <span class="text-muted small">/@pricing.BillingFrequencyLabel</span>
                                        </span>
                                    }
                                }
                            </div>

                            @* Features list *@
                            @if (tier.Features.Any())
                            {
                                <ul class="list-unstyled small mb-3">
                                    @foreach (var feature in tier.Features)
                                    {
                                        <li class="mb-1">
                                            <i class="bi @(feature.IsEnabled ? "bi-check-circle-fill text-success" : "bi-x-circle text-muted") me-1"></i>
                                            @feature.DisplayName
                                        </li>
                                    }
                                </ul>
                            }

                            @* Limits *@
                            @if (tier.Limits.Any())
                            {
                                <ul class="list-unstyled small mb-3 border-top pt-2">
                                    @foreach (var limit in tier.Limits)
                                    {
                                        <li class="mb-1">
                                            <i class="bi bi-speedometer2 text-info me-1"></i>
                                            @limit.DisplayName: <strong>@limit.MaxValueDisplay</strong> @limit.Unit
                                        </li>
                                    }
                                </ul>
                            }

                            <div class="mt-auto text-center">
                                @if (isCurrentPlan)
                                {
                                    <span class="text-muted small"><i class="bi bi-check me-1"></i> Active</span>
                                }
                                else if (isEnterprise && tier.ShowContactButton)
                                {
                                    <a href="@(tier.ContactButtonUrl ?? "#")" class="btn btn-outline-primary btn-sm">Contact Sales</a>
                                }
                                else if (tier.ShowSubscribeButton)
                                {
                                    var isChange = Model.Subscription != null && Model.Subscription.IsActive;
                                    <button type="button" class="btn btn-primary btn-sm ww-select-tier-btn"
                                            data-tier-id="@tier.Id" data-tier-name="@tier.Name"
                                            data-is-change="@isChange.ToString().ToLower()"
                                            data-is-free="@tier.IsFreeTier.ToString().ToLower()"
                                            data-action="select-tier">
                                        @(isChange ? "Switch" : "Select")
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
