@using WildwoodComponents.Razor.Models
@model NotificationToastViewModel

@{
    var cid = Model.ComponentId;

    var posClass = Model.Position switch
    {
        "TopLeft" => "ww-toast-top-left",
        "TopCenter" => "ww-toast-top-center",
        "TopRight" => "ww-toast-top-right",
        "BottomLeft" => "ww-toast-bottom-left",
        "BottomCenter" => "ww-toast-bottom-center",
        "BottomRight" => "ww-toast-bottom-right",
        _ => "ww-toast-top-right"
    };
}

<div id="ww-toast-@cid"
     class="ww-toast-component @posClass"
     data-component-id="@cid"
     data-position="@Model.Position"
     data-default-duration="@Model.DefaultDuration"
     data-max-visible="@Model.MaxVisible"
     data-show-dismiss-all="@Model.ShowDismissAll.ToString().ToLower()">

    @* Dismiss All button *@
    @if (Model.ShowDismissAll)
    {
        <div class="ww-toast-dismiss-all" id="ww-toast-dismiss-all-@cid" style="display:none;">
            <button type="button" class="btn btn-sm btn-link text-muted ww-toast-dismiss-all-btn">
                Clear all
            </button>
        </div>
    }

    @* Toast items container *@
    <div class="ww-toast-items" id="ww-toast-items-@cid"></div>

    @* Toast item template (cloned by JS) *@
    <template id="ww-toast-template-@cid">
        <div class="ww-toast-item" role="alert" aria-live="polite" aria-atomic="true">
            <div class="ww-toast-body">
                <div class="ww-toast-icon-wrap">
                    <i class="bi ww-toast-icon"></i>
                </div>
                <div class="ww-toast-text">
                    <div class="ww-toast-title"></div>
                    <div class="ww-toast-message"></div>
                </div>
                <button type="button" class="ww-toast-close" aria-label="Dismiss">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="ww-toast-actions"></div>
            <div class="ww-toast-timer">
                <div class="ww-toast-timer-bar"></div>
            </div>
        </div>
    </template>
</div>

<style>
    .ww-toast-component {
        --ww-toast-bg: var(--ww-bg-primary, #ffffff);
        --ww-toast-text: var(--ww-text-primary, #212529);
        --ww-toast-text-secondary: var(--ww-text-secondary, #6c757d);
        --ww-toast-border: var(--ww-border-color, #dee2e6);
        --ww-toast-shadow: var(--ww-shadow, 0 0.5rem 1rem rgba(0, 0, 0, 0.15));
        --ww-toast-radius: 0.5rem;
        --ww-toast-success: var(--ww-success, #198754);
        --ww-toast-success-bg: rgba(25, 135, 84, 0.08);
        --ww-toast-danger: var(--ww-danger, #dc3545);
        --ww-toast-danger-bg: rgba(220, 53, 69, 0.08);
        --ww-toast-warning: var(--ww-warning, #ffc107);
        --ww-toast-warning-bg: rgba(255, 193, 7, 0.08);
        --ww-toast-info: var(--ww-info, #0dcaf0);
        --ww-toast-info-bg: rgba(13, 202, 240, 0.08);
        --ww-toast-width: 360px;
        --ww-toast-gap: 0.5rem;
        --ww-toast-offset: 1.5rem;

        position: fixed;
        z-index: 1090;
        display: flex;
        flex-direction: column;
        gap: var(--ww-toast-gap);
        width: var(--ww-toast-width);
        max-width: calc(100vw - 2rem);
        pointer-events: none;
    }

    .ww-toast-component > * {
        pointer-events: auto;
    }

    /* Position classes */
    .ww-toast-top-right { top: var(--ww-toast-offset); right: var(--ww-toast-offset); }
    .ww-toast-top-left { top: var(--ww-toast-offset); left: var(--ww-toast-offset); }
    .ww-toast-top-center { top: var(--ww-toast-offset); left: 50%; transform: translateX(-50%); }
    .ww-toast-bottom-right { bottom: var(--ww-toast-offset); right: var(--ww-toast-offset); }
    .ww-toast-bottom-left { bottom: var(--ww-toast-offset); left: var(--ww-toast-offset); }
    .ww-toast-bottom-center { bottom: var(--ww-toast-offset); left: 50%; transform: translateX(-50%); }

    /* Bottom positions stack upward */
    .ww-toast-bottom-right,
    .ww-toast-bottom-left,
    .ww-toast-bottom-center {
        flex-direction: column-reverse;
    }

    .ww-toast-dismiss-all {
        text-align: end;
    }

    /* Toast item */
    .ww-toast-item {
        background-color: var(--ww-toast-bg);
        border: 1px solid var(--ww-toast-border);
        border-radius: var(--ww-toast-radius);
        box-shadow: var(--ww-toast-shadow);
        overflow: hidden;
        animation: ww-toast-slide-in 0.35s cubic-bezier(0.21, 1.02, 0.73, 1);
    }

    .ww-toast-item.ww-toast-removing {
        animation: ww-toast-slide-out 0.3s ease-in forwards;
    }

    .ww-toast-body {
        display: flex;
        align-items: flex-start;
        gap: 0.625rem;
        padding: 0.75rem 0.875rem;
    }

    .ww-toast-icon-wrap {
        flex-shrink: 0;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .ww-toast-text {
        flex: 1;
        min-width: 0;
    }

    .ww-toast-title {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--ww-toast-text);
        line-height: 1.3;
    }

    .ww-toast-title:empty {
        display: none;
    }

    .ww-toast-message {
        font-size: 0.8125rem;
        color: var(--ww-toast-text-secondary);
        line-height: 1.4;
        margin-top: 0.125rem;
    }

    .ww-toast-close {
        flex-shrink: 0;
        background: none;
        border: none;
        color: var(--ww-toast-text-secondary);
        cursor: pointer;
        padding: 0.125rem;
        font-size: 0.75rem;
        line-height: 1;
        opacity: 0.5;
        transition: opacity 0.15s;
    }

    .ww-toast-close:hover {
        opacity: 1;
    }

    .ww-toast-actions {
        display: flex;
        gap: 0.5rem;
        padding: 0 0.875rem 0.625rem;
        padding-top: 0;
    }

    .ww-toast-actions:empty {
        display: none;
    }

    .ww-toast-actions .btn {
        font-size: 0.8125rem;
        padding: 0.25rem 0.625rem;
    }

    /* Timer bar */
    .ww-toast-timer {
        height: 3px;
        background-color: var(--ww-toast-border);
        overflow: hidden;
    }

    .ww-toast-timer-bar {
        height: 100%;
        width: 100%;
        transform-origin: left;
        transition: transform linear;
    }

    /* Type-specific styling */
    .ww-toast-item[data-type="Success"] { border-left: 3px solid var(--ww-toast-success); }
    .ww-toast-item[data-type="Success"] .ww-toast-icon-wrap {
        background-color: var(--ww-toast-success-bg);
        color: var(--ww-toast-success);
    }
    .ww-toast-item[data-type="Success"] .ww-toast-timer-bar { background-color: var(--ww-toast-success); }

    .ww-toast-item[data-type="Error"] { border-left: 3px solid var(--ww-toast-danger); }
    .ww-toast-item[data-type="Error"] .ww-toast-icon-wrap {
        background-color: var(--ww-toast-danger-bg);
        color: var(--ww-toast-danger);
    }
    .ww-toast-item[data-type="Error"] .ww-toast-timer-bar { background-color: var(--ww-toast-danger); }

    .ww-toast-item[data-type="Warning"] { border-left: 3px solid var(--ww-toast-warning); }
    .ww-toast-item[data-type="Warning"] .ww-toast-icon-wrap {
        background-color: var(--ww-toast-warning-bg);
        color: var(--ww-toast-warning);
    }
    .ww-toast-item[data-type="Warning"] .ww-toast-timer-bar { background-color: var(--ww-toast-warning); }

    .ww-toast-item[data-type="Info"] { border-left: 3px solid var(--ww-toast-info); }
    .ww-toast-item[data-type="Info"] .ww-toast-icon-wrap {
        background-color: var(--ww-toast-info-bg);
        color: var(--ww-toast-info);
    }
    .ww-toast-item[data-type="Info"] .ww-toast-timer-bar { background-color: var(--ww-toast-info); }

    /* Slide-in animations */
    @@keyframes ww-toast-slide-in {
        from {
            opacity: 0;
            transform: translateX(100%) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateX(0) scale(1);
        }
    }

    .ww-toast-top-left .ww-toast-item,
    .ww-toast-bottom-left .ww-toast-item {
        animation-name: ww-toast-slide-in-left;
    }

    @@keyframes ww-toast-slide-in-left {
        from {
            opacity: 0;
            transform: translateX(-100%) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateX(0) scale(1);
        }
    }

    .ww-toast-top-center .ww-toast-item,
    .ww-toast-bottom-center .ww-toast-item {
        animation-name: ww-toast-slide-in-center;
    }

    @@keyframes ww-toast-slide-in-center {
        from {
            opacity: 0;
            transform: translateY(-1.5rem) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .ww-toast-bottom-center .ww-toast-item {
        animation-name: ww-toast-slide-in-center-up;
    }

    @@keyframes ww-toast-slide-in-center-up {
        from {
            opacity: 0;
            transform: translateY(1.5rem) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes ww-toast-slide-out {
        to {
            opacity: 0;
            transform: translateX(100%) scale(0.9);
            max-height: 0;
            margin: 0;
            padding: 0;
            border-width: 0;
        }
    }

    /* Hover pause effect */
    .ww-toast-item:hover .ww-toast-timer-bar {
        animation-play-state: paused !important;
    }

    /* Responsive */
    @@media (max-width: 480px) {
        .ww-toast-component {
            --ww-toast-width: calc(100vw - 2rem);
            --ww-toast-offset: 1rem;
        }
    }
</style>
