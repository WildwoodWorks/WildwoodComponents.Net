@rendermode InteractiveServer

<div class="settings-panel">
    <div class="card">
        <div class="card-header py-2 d-flex justify-content-between align-items-center" @onclick="ToggleCollapse">
            <h6 class="mb-0">
                <i class="fas fa-cog me-2"></i>@Title
            </h6>
            <i class="fas fa-chevron-down collapse-icon @(isCollapsed ? "collapsed" : "")"></i>
        </div>
        @if (!isCollapsed)
        {
            <div class="card-body py-2 px-3">
                @ChildContent

                <div class="d-flex gap-2 mt-2 pt-2 border-top">
                    <button class="btn btn-primary btn-sm" @onclick="OnApply">
                        <i class="fas fa-check me-1"></i>Apply
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="OnReset">
                        <i class="fas fa-undo me-1"></i>Reset
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Settings";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnApply { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public bool StartCollapsed { get; set; } = false;

    private bool isCollapsed;

    protected override void OnInitialized()
    {
        isCollapsed = StartCollapsed;
    }

    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
    }
}
