@page "/test/usage-dashboard"
@rendermode InteractiveServer
@using WildwoodComponents.Blazor.Components.Base
@using WildwoodComponents.Blazor.Components.Usage
@using WildwoodComponents.Blazor.Models
@inject CircuitStateStorageService StateStorage
@inject ComponentLifecycleTracker LifecycleTracker
@inject IConfiguration Configuration
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<ComponentTestPage PageTitle="UsageDashboardComponent Test" ComponentName="UsageDashboardComponent" IconClass="fas fa-chart-bar"
                   OnApplySettings="ApplySettings" OnResetSettings="ResetSettings">
    <Settings>
        <div class="mb-2">
            <label class="form-label">AppId</label>
            <input class="form-control form-control-sm" @bind="appId" />
        </div>
        <div class="mb-2">
            <label class="form-label">Title</label>
            <input class="form-control form-control-sm" @bind="title" />
        </div>
        <div class="mb-2">
            <label class="form-label">Subtitle</label>
            <input class="form-control form-control-sm" @bind="subtitle" />
        </div>
        <div class="mb-2">
            <label class="form-label">Warning Threshold (%)</label>
            <input class="form-control form-control-sm" type="number" @bind="warningThreshold" />
        </div>
        <div class="mb-2">
            <label class="form-label">Refresh Interval (seconds, 0=off)</label>
            <input class="form-control form-control-sm" type="number" @bind="refreshInterval" />
        </div>
        <hr class="my-2" />
        <div class="form-check mb-1">
            <input class="form-check-input" type="checkbox" @bind="showOverageInfo" id="chkUsageOverage" />
            <label class="form-check-label small" for="chkUsageOverage">Show Overage Info</label>
        </div>
        <div class="form-check mb-1">
            <input class="form-check-input" type="checkbox" @bind="showOverageSummary" id="chkOverageSummary" />
            <label class="form-check-label small" for="chkOverageSummary">Show Overage Summary</label>
        </div>
        @if (showOverageSummary)
        {
            <div class="mb-2 mt-2">
                <label class="form-label">Overage Rate ($/unit)</label>
                <input class="form-control form-control-sm" type="number" step="0.0001" @bind="overageRate" />
            </div>
        }
    </Settings>
    <Component>
        <UsageDashboardComponent AppId="@appId"
                                  Title="@title"
                                  Subtitle="@subtitle"
                                  ShowOverageInfo="@showOverageInfo"
                                  WarningThreshold="@warningThreshold"
                                  RefreshIntervalSeconds="@refreshInterval"
                                  OnUpgradeClick="HandleUpgradeClick"
                                  OnError="HandleError" />
        @if (showOverageSummary)
        {
            <div class="mt-3">
                <OverageSummaryComponent AppId="@appId"
                                          OverageRate="@overageRate"
                                          OnViewDetails="HandleViewOverageDetails"
                                          OnError="HandleError" />
            </div>
        }
    </Component>
    <EventLog>
        @foreach (var evt in events)
        {
            <div class="event-entry">
                <span class="event-timestamp">@evt.Time.ToString("HH:mm:ss.fff")</span>
                <span class="ms-2">@evt.Message</span>
            </div>
        }
    </EventLog>
</ComponentTestPage>

@code {
    private string appId = "";
    private string title = "Usage Overview";
    private string subtitle = "Monitor your current usage across all limits";
    private bool showOverageInfo = true;
    private int warningThreshold = 80;
    private int refreshInterval = 0;
    private bool showOverageSummary = true;
    private decimal overageRate = 0.003m;
    private List<EventEntry> events = new();

    protected override void OnInitialized()
    {
        appId = Configuration["WildwoodAPI:AppId"] ?? "";
        LifecycleTracker.TrackInitialized("UsageDashboardComponent");
    }

    private void HandleUpgradeClick()
    {
        var msg = "Upgrade clicked";
        events.Insert(0, new EventEntry(DateTime.Now, msg));
        LifecycleTracker.TrackCallback("UsageDashboardComponent", "OnUpgradeClick", msg);
        StateHasChanged();
    }

    private void HandleViewOverageDetails()
    {
        var msg = "View overage details clicked";
        events.Insert(0, new EventEntry(DateTime.Now, msg));
        LifecycleTracker.TrackCallback("OverageSummaryComponent", "OnViewDetails", msg);
        StateHasChanged();
    }

    private void HandleError(ComponentErrorEventArgs args)
    {
        var msg = $"Error: {args.Exception.Message}";
        events.Insert(0, new EventEntry(DateTime.Now, msg));
        LifecycleTracker.TrackError("UsageDashboardComponent", args.Exception.Message);
        StateHasChanged();
    }

    private void ApplySettings() { StateHasChanged(); }

    private void ResetSettings()
    {
        appId = Configuration["WildwoodAPI:AppId"] ?? "";
        title = "Usage Overview";
        subtitle = "Monitor your current usage across all limits";
        showOverageInfo = true;
        warningThreshold = 80;
        refreshInterval = 0;
        showOverageSummary = true;
        overageRate = 0.003m;
        events.Clear();
        StateHasChanged();
    }

    private record EventEntry(DateTime Time, string Message);
}
